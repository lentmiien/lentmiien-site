extends layout

block styles
  link(rel='stylesheet', href='/css/openaiUsage.css')

block content
  - const formatWholeNumber = (value) => new Intl.NumberFormat('en-US').format(Number(value) || 0);
  - const formatCompactNumber = (value) => new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 }).format(Number(value) || 0);
  - const formatCurrency = (value) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(Number(value) || 0);
  - const trendIcon = (direction) => ({ up: '↑', down: '↓', new: '✦', flat: '→', unavailable: '–' }[direction] || '–');
  - const trendShortLabel = (trend) => trend.direction === 'up' ? `+${trend.percent}%` : trend.direction === 'down' ? `−${trend.percent}%` : trend.direction === 'new' ? 'New' : trend.direction === 'flat' ? '0%' : 'No comparison';
  .openai-usage
    .openai-usage__header
      h1 OpenAI Usage
      p.openai-usage__subtitle Visualize spending trends and drill into detailed activity.

    if feedback && feedback.message
      .openai-usage__alert(class=`openai-usage__alert--${feedback.status || 'info'}`, role='alert')= feedback.message

    if spendingInsights
      section.spending-summary-card(aria-labelledby='totalSpendTitle')
        .spending-summary-card__primary
          h2.spending-summary-card__eyebrow#totalSpendTitle All-time OpenAI spend
          strong.spending-summary-card__total= formatCurrency(spendingInsights.totalSpend)
          p.spending-summary-card__period
            | #{spendingInsights.monthsIncluded} #{spendingInsights.monthsIncluded === 1 ? 'month' : 'months'} included · #{spendingInsights.periodStartLabel} – #{spendingInsights.periodEndLabel}#{spendingInsights.periodEndIsCurrentMonth ? ' (to date)' : ''}
        dl.spending-summary-card__breakdown
          div
            dt API usage
            dd= formatCurrency(spendingInsights.totalApiSpend)
          div
            dt ChatGPT plans
            dd= formatCurrency(spendingInsights.totalSubscriptionSpend)

    if monthlyTimeline && monthlyTimeline.length
      section.openai-usage__section
        header.section-header
          h2.section-title Monthly Spending Overview
          p.section-subtitle Track API usage and ChatGPT subscription spending across months.
        #monthlyUsageChart.chart-container(data-chart='monthly')
    else
      .openai-usage__empty
        p No usage data available yet.

    if spendingInsights
      section.openai-usage__section
        header.section-header
          h2.section-title Centered Five-Month Rolling Average
          p.section-subtitle Combined API and ChatGPT spend for each month, averaged with the two months before and after it. Only complete calendar months are used.
        if spendingInsights.rollingAveragePointCount
          #rollingSpendingChart.chart-container.spending-chart(
            role='img',
            aria-label='Combined monthly OpenAI spending and centered five-month average'
          )
        else
          .openai-usage__empty.openai-usage__empty--panel
            p Five complete months are needed before the centered average can be shown.

    if spendingInsights && spendingInsights.weekdayTrackedDays
      section.openai-usage__section
        header.section-header
          h2.section-title Weekday Spending Pattern
          p.section-subtitle Across all stored daily usage, this shows average API spend per tracked UTC day. ChatGPT plan costs are excluded because they are billed monthly rather than by weekday.
        #weekdaySpendingChart.chart-container.spending-chart.spending-chart--weekday(
          role='img',
          aria-label='Average API spending by weekday'
        )

    if completionInsights
      section.openai-usage__section
        header.section-header.completion-section__header
          .completion-section__heading
            h2.section-title Key Metrics
            p.section-subtitle Completion activity from #{completionInsights.periodLabel}. Lifetime usage and low-volume API categories are excluded.
          .completion-period-badge(aria-label=`${completionInsights.trackedDays} of ${completionInsights.periodDays} days have stored usage data`)
            span Recent window
            strong #{completionInsights.trackedDays}/#{completionInsights.periodDays} days tracked

        if completionInsights.hasActivity
          .completion-metrics-grid
            article.completion-stat-card
              .completion-stat-card__topline
                span.completion-stat-card__label Requests
                span.completion-trend(class=`completion-trend--${completionInsights.requestTrend.direction}`, title=completionInsights.requestTrend.label, aria-label=completionInsights.requestTrend.label)
                  span.completion-trend__icon(aria-hidden='true')= trendIcon(completionInsights.requestTrend.direction)
                  span= trendShortLabel(completionInsights.requestTrend)
              strong.completion-stat-card__value= formatWholeNumber(completionInsights.requests)
              p.completion-stat-card__detail
                if completionInsights.activeDays > 0
                  | #{formatWholeNumber(completionInsights.requestsPerActiveDay)} per active day across #{completionInsights.activeDays} #{completionInsights.activeDays === 1 ? 'day' : 'days'}
                else
                  | No request-bearing days in this window

            article.completion-stat-card
              .completion-stat-card__topline
                span.completion-stat-card__label Tokens processed
                span.completion-trend(class=`completion-trend--${completionInsights.tokenTrend.direction}`, title=completionInsights.tokenTrend.label, aria-label=completionInsights.tokenTrend.label)
                  span.completion-trend__icon(aria-hidden='true')= trendIcon(completionInsights.tokenTrend.direction)
                  span= trendShortLabel(completionInsights.tokenTrend)
              strong.completion-stat-card__value(title=`${formatWholeNumber(completionInsights.tokens)} tokens`)= formatCompactNumber(completionInsights.tokens)
              p.completion-stat-card__detail #{formatCompactNumber(completionInsights.inputTokens)} input · #{formatCompactNumber(completionInsights.outputTokens)} output
              if completionInsights.cachedTokens > 0
                p.completion-stat-card__note #{formatCompactNumber(completionInsights.cachedTokens)} cached input (#{completionInsights.cacheRate}%)

            article.completion-stat-card.completion-stat-card--featured
              .completion-stat-card__topline
                span.completion-stat-card__label Leading model
                span.completion-stat-card__share #{completionInsights.topModel.requestShare}% of requests
              strong.completion-stat-card__value.completion-stat-card__value--model= completionInsights.topModel.model
              p.completion-stat-card__detail #{formatWholeNumber(completionInsights.topModel.requests)} requests · last used #{completionInsights.topModel.latestDateLabel}

            article.completion-stat-card
              .completion-stat-card__topline
                span.completion-stat-card__label Active models
                span.completion-stat-card__share Last #{completionInsights.periodDays} days
              strong.completion-stat-card__value= formatWholeNumber(completionInsights.activeModels)
              p.completion-stat-card__detail #{completionInsights.activeModelsLast7Days} used in the latest 7 days
              p.completion-stat-card__note #{completionInsights.activeDays} completion-active #{completionInsights.activeDays === 1 ? 'day' : 'days'}

          .completion-detail-grid
            article.completion-panel.completion-panel--activity
              header.completion-panel__header
                div
                  h3 Daily request rhythm
                  p Daily completion requests with a trailing 7-day average.
                .completion-panel__legend(aria-label='Chart legend')
                  span
                    i.completion-panel__legend-swatch(aria-hidden='true')
                    | Requests
                  span
                    i.completion-panel__legend-line(aria-hidden='true')
                    | 7-day average
              #completionActivityChart.completion-activity-chart(
                role='img',
                aria-label=`Daily completion requests from ${completionInsights.periodLabel}`
              )

            article.completion-panel.completion-panel--models
              header.completion-panel__header
                div
                  h3 Recent model mix
                  p Ranked only within this #{completionInsights.periodDays}-day window.
              ol.completion-model-list
                each model, index in completionInsights.models.slice(0, 6)
                  li.completion-model
                    .completion-model__heading
                      span.completion-model__rank= index + 1
                      strong.completion-model__name= model.model
                      span.completion-model__share #{model.requestShare}%
                    progress.completion-model__bar(
                      value=model.requestShare,
                      max='100',
                      aria-label=`${model.model}: ${model.requestShare}% of recent completion requests`
                    )
                    .completion-model__meta
                      span #{formatWholeNumber(model.requests)} requests
                      span #{formatCompactNumber(model.tokens)} tokens
                      span Last used #{model.latestDateLabel}
              if completionInsights.models.length > 6
                p.completion-model__more +#{completionInsights.models.length - 6} more active #{completionInsights.models.length - 6 === 1 ? 'model' : 'models'}
        else
          .completion-empty-state
            strong No recent completion activity
            p There are stored usage days in this window, but none contain completion requests or tokens.

    if monthlyCards && monthlyCards.length
      section.openai-usage__section
        header.section-header
          h2.section-title Monthly Details
          p.section-subtitle Expand a month to view daily trends and activity highlights.
        .month-card-grid
          each monthData in monthlyCards
            details.month-card(data-month=monthData.month)
              summary.month-card__summary
                .summary-content
                  .summary-heading
                    span.summary-month= monthData.label
                    span.summary-total= `$${monthData.totalCost.toFixed(2)}`
                  span.summary-meta API $#{monthData.apiCost.toFixed(2)} · #{monthData.subscriptionPlanName || 'Free'} $#{monthData.subscriptionCost.toFixed(2)} · #{monthData.dailyEntries.length} #{monthData.dailyEntries.length === 1 ? 'day' : 'days'} tracked
              .month-card__body
                .month-card__chart
                  .month-card__chart-container(data-month=monthData.month)
                if monthData.dailyEntries && monthData.dailyEntries.length
                  .month-card__table-wrapper
                    table.table.table-sm.month-card__table
                      thead
                        tr
                          th(scope='col') Date
                          th(scope='col') Cost (USD)
                          th(scope='col') Highlights
                      tbody
                        each entry in monthData.dailyEntries
                          - const highlightParts = [];
                          if entry.completions && entry.completions.length
                            - highlightParts.push(`${entry.completions.length} completions`);
                          if entry.embeddings && entry.embeddings.length
                            - highlightParts.push(`${entry.embeddings.length} embeddings`);
                          if entry.images && entry.images.length
                            - highlightParts.push(`${entry.images.length} images`);
                          if entry.speeches && entry.speeches.length
                            - highlightParts.push(`${entry.speeches.length} speech jobs`);
                          if entry.transcriptions && entry.transcriptions.length
                            - highlightParts.push(`${entry.transcriptions.length} transcriptions`);
                          tr
                            td= entry.date
                            td= `$${entry.cost.toFixed(2)}`
                            td= highlightParts.length ? highlightParts.join(' · ') : 'N/A'

    section.openai-usage__section.openai-subscriptions
      header.section-header
        h2.section-title ChatGPT Subscription
        p.section-subtitle Monthly plan costs are stacked on top of API usage in the overview.
      .subscription-layout
        .subscription-panel
          h3.subscription-panel__title Applied By Month
          if subscriptionMonthlyRows && subscriptionMonthlyRows.length
            .subscription-table-wrapper
              table.table.table-sm.subscription-table
                thead
                  tr
                    th(scope='col') Month
                    th(scope='col') Plan
                    th(scope='col') Start date
                    th(scope='col') Cost
                tbody
                  each row in subscriptionMonthlyRows
                    tr
                      td= row.label
                      td= row.planName
                      td= row.planStartDate || 'Default'
                      td= `$${row.subscriptionCost.toFixed(2)}`
          else
            p.subscription-empty Free $0 applies until a subscription plan is saved.
        .subscription-panel
          h3.subscription-panel__title Switch Plan
          form.subscription-form(method='post', action='/admin/openai_usage/subscription-plans')
            input(type='hidden', name='return_to', value='/admin/openai_usage')
            label.subscription-form__field(for='subscriptionPlanName')
              span Plan
              input#subscriptionPlanName(type='text', name='plan_name', placeholder='Pro', maxlength='80', required)
            label.subscription-form__field(for='subscriptionStartDate')
              span Start date
              input#subscriptionStartDate(type='date', name='start_date', required)
            label.subscription-form__field(for='subscriptionMonthlyCost')
              span Monthly cost
              input#subscriptionMonthlyCost(type='number', name='monthly_cost', min='0', step='0.01', placeholder='100.00', required)
            button.subscription-form__button(type='submit') Save plan
          if subscriptionPlans && subscriptionPlans.length
            .subscription-history
              h4.subscription-history__title Plan Changes
              ul.subscription-history__list
                each plan in subscriptionPlans
                  li
                    span.subscription-history__plan= plan.planName
                    span.subscription-history__meta #{plan.startDate} · $#{plan.monthlyCost.toFixed(2)}

block script
  script(src='https://d3js.org/d3.v7.min.js', defer)
  script(type='application/json', id='openaiUsageData') !{JSON.stringify({ monthlyTimeline, monthlyCards, completionInsights, spendingInsights })}
  script(src='/js/openaiUsage.js', defer)
