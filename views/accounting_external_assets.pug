extends layout

block styles
  link(rel='stylesheet', href='/css/accounting.css')

block content
  - const assets = externalAssets && externalAssets.assets ? externalAssets.assets : []
  - const totals = externalAssets && externalAssets.totals ? externalAssets.totals : {}
  - const exchangeRate = externalAssets && externalAssets.exchangeRate ? externalAssets.exchangeRate : {}
  - const formatJpy = (value) => value === null || value === undefined || Number.isNaN(Number(value)) ? '--' : `${Math.round(Number(value)).toLocaleString()} JPY`
  - const formatAmount = (value, currency) => value === null || value === undefined || Number.isNaN(Number(value)) ? '--' : `${Number(value).toLocaleString(undefined, { maximumFractionDigits: 2 })} ${currency || ''}`
  - const formatSignedJpy = (value) => value === null || value === undefined || Number.isNaN(Number(value)) ? '--' : `${Number(value) >= 0 ? '+' : '-'}${Math.round(Math.abs(Number(value))).toLocaleString()} JPY`
  .accounting-app.external-assets-page
    .accounting-hero
      .hero-text
        h1 External Assets
        p.mb-0 Savings accounts and loans outside the main accounting ledger.
        .hero-actions.mt-3
          a.btn.btn-outline-light(href='/accounting/business-analytics/overall') Economic dashboard
          a.btn.btn-outline-light(href='/accounting') Accounting
      .hero-metrics
        .metric-card
          span.metric-label Savings
          strong.metric-value= formatJpy(totals.savingsJpy)
        .metric-card
          span.metric-label Loans
          strong.metric-value.metric-negative= formatJpy(totals.loanJpy)
        .metric-card
          span.metric-label Net external
          strong.metric-value(class=Number(totals.netJpy) < 0 ? 'metric-negative' : 'metric-positive')= formatSignedJpy(totals.netJpy)
        .metric-card
          span.metric-label Exchange date
          strong.metric-value= exchangeRate.date || '--'
    section.accounting-card
      .section-header
        h2 Add external asset
        p#externalAssetFeedback.inline-feedback.mb-0
      form#externalAssetForm.external-asset-form
        .external-asset-form-grid
          .form-group
            label.form-label(for='assetName') Name
            input#assetName.form-control(name='name', type='text', required, autocomplete='off')
          .form-group
            label.form-label(for='assetKind') Type
            select#assetKind.form-select(name='kind')
              option(value='savings') Savings
              option(value='loan') Loan
          .form-group
            label.form-label(for='assetCurrency') Currency
            input#assetCurrency.form-control(name='currency', type='text', value='JPY', maxlength='3', required)
          .form-group
            label.form-label(for='assetCurrentBalance') Current balance
            input#assetCurrentBalance.form-control(name='currentBalance', type='number', min='0', step='0.01', value='0', required)
          .form-group
            label.form-label(for='assetBalanceDate') Balance date
            input#assetBalanceDate.form-control(name='balanceDate', type='date')
          .form-group
            label.form-label(for='assetMonthlyPayment') Monthly payment
            input#assetMonthlyPayment.form-control(name='monthlyPayment', type='number', min='0', step='0.01', value='0')
          .form-group
            label.form-label(for='assetAnnualInterestRate') APR %
            input#assetAnnualInterestRate.form-control(name='annualInterestRate', type='number', step='0.001', value='0')
          .form-group
            label.form-label(for='assetCompounding') Compounding
            select#assetCompounding.form-select(name='compounding')
              option(value='monthly') Monthly
              option(value='yearly') Yearly
              option(value='none') None
          .form-group
            label.form-label(for='assetStartDate') Start date
            input#assetStartDate.form-control(name='startDate', type='date')
          .form-group
            label.form-label(for='assetScheduledEndDate') Scheduled end
            input#assetScheduledEndDate.form-control(name='scheduledEndDate', type='date')
          .form-group.external-asset-notes
            label.form-label(for='assetNotes') Notes
            input#assetNotes.form-control(name='notes', type='text', autocomplete='off')
          .form-group.external-asset-submit
            button.btn.btn-primary.w-100(type='submit') Add
    section.accounting-card
      .section-header
        h2 Current external assets
        p.mb-0= totals.unavailableCount ? `${totals.unavailableCount} asset(s) need exchange-rate data before JPY totals are complete.` : 'JPY totals use the latest known exchange-rate record.'
      .business-period-table-wrap
        table.table.table-dark.table-striped.table-sm.external-assets-table
          thead
            tr
              th Name
              th Type
              th Currency
              th Balance
              th JPY value
              th Monthly
              th APR %
              th Compounding
              th Dates
              th Notes
              th
          tbody
            if assets.length
              each asset in assets
                tr(data-asset-id=asset.id)
                  td
                    input.form-control.form-control-sm.external-asset-input(data-field='name', value=asset.name)
                  td
                    select.form-select.form-select-sm.external-asset-input(data-field='kind')
                      option(value='savings', selected=asset.kind === 'savings') Savings
                      option(value='loan', selected=asset.kind === 'loan') Loan
                  td
                    input.form-control.form-control-sm.external-asset-input.external-asset-currency(data-field='currency', value=asset.currency, maxlength='3')
                  td
                    input.form-control.form-control-sm.external-asset-input(data-field='currentBalance', type='number', min='0', step='0.01', value=asset.currentBalance)
                    small.muted-text= formatAmount(asset.signedBalance, asset.currency)
                  td
                    strong(class=Number(asset.signedBalanceJpy) < 0 ? 'metric-negative' : 'metric-positive')= formatSignedJpy(asset.signedBalanceJpy)
                    if asset.exchangeRate && asset.exchangeRate.available === false
                      small.muted-text.d-block Missing FX
                  td
                    input.form-control.form-control-sm.external-asset-input(data-field='monthlyPayment', type='number', min='0', step='0.01', value=asset.monthlyPayment)
                  td
                    input.form-control.form-control-sm.external-asset-input(data-field='annualInterestRate', type='number', step='0.001', value=asset.annualInterestRate)
                  td
                    select.form-select.form-select-sm.external-asset-input(data-field='compounding')
                      option(value='monthly', selected=asset.compounding === 'monthly') Monthly
                      option(value='yearly', selected=asset.compounding === 'yearly') Yearly
                      option(value='none', selected=asset.compounding === 'none') None
                  td.external-asset-date-cell
                    input.form-control.form-control-sm.external-asset-input(data-field='startDate', type='date', value=asset.startDate)
                    input.form-control.form-control-sm.external-asset-input(data-field='scheduledEndDate', type='date', value=asset.scheduledEndDate)
                    input.form-control.form-control-sm.external-asset-input(data-field='balanceDate', type='date', value=asset.balanceDate)
                  td
                    input.form-control.form-control-sm.external-asset-input(data-field='notes', value=asset.notes)
                  td.text-end.external-asset-actions
                    button.btn.btn-outline-primary.btn-sm.external-asset-save(type='button') Save
                    button.btn.btn-outline-light.btn-sm.external-asset-payment(type='button') Add monthly
                    button.btn.btn-outline-danger.btn-sm.external-asset-delete(type='button') Delete
            else
              tr
                td.text-muted(colspan='11') No external assets yet.

block script
  script.
    window.externalAssetsState = {
      routes: {
        assets: '/accounting/api/external-assets'
      }
    };
  script(src='/js/accounting_external_assets.js', defer)
