extends layout

block content
  - const amountValue = typeof budgetPrefill !== 'undefined' && budgetPrefill && budgetPrefill.amount !== undefined ? budgetPrefill.amount : (creditPrefill && creditPrefill.amount !== undefined ? creditPrefill.amount : '');
  - const budgetDateValue = budgetPrefill && budgetPrefill.date ? budgetPrefill.date : (receipt && receipt.date ? receipt.date.toISOString().split('T')[0] : '');
  - const creditDateValue = creditPrefill && creditPrefill.transactionDate ? creditPrefill.transactionDate : budgetDateValue;
  - const typeOptions = Array.isArray(types) && types.length ? types : ['income', 'expense', 'saving'];
  - const autocompleteSuggestions = typeof receiptAutocomplete !== 'undefined' && receiptAutocomplete ? receiptAutocomplete : {};
  - const businessSuggestions = Array.isArray(autocompleteSuggestions.businesses) ? autocompleteSuggestions.businesses : [];
  - const tagSuggestions = Array.isArray(autocompleteSuggestions.tags) ? autocompleteSuggestions.tags : [];
  - const creditLabelSuggestions = Array.isArray(autocompleteSuggestions.creditLabels) ? autocompleteSuggestions.creditLabels : [];
  .receipt-entry-page
    h1 Add receipt to ledger
    p.page-intro Turn this receipt into a budget or credit-card entry with your saved mapping rules.

    section.section-card
      h2 Receipt snapshot
      .entry-meta-grid
        .meta-chip
          span.meta-label Amount
          strong.meta-value= amountValue !== undefined && amountValue !== null ? amountValue : '—'
        .meta-chip
          span.meta-label Date
          strong.meta-value= budgetDateValue || 'Unknown'
        .meta-chip
          span.meta-label Method
          strong.meta-value= receipt.method || 'N/A'
        .meta-chip
          span.meta-label Business
          strong.meta-value= receipt.business_name || 'N/A'
      if receipt.business_address
        p.text-muted.small.mb-2 #{receipt.business_address}
      .snapshot-actions
        a.btn.btn-outline-light.btn-sm(href=`/receipt/view_receipt/${receipt._id.toString()}`, target='_blank', rel='noopener') View receipt details
        a.btn.btn-outline-secondary.btn-sm(href='/receipt') Back to inbox
      if receipt.layout_text
        details.layout-snippet-block
          summary.text-muted.small OCR text preview
          pre.layout-snippet= receipt.layout_text.length > 900 ? receipt.layout_text.slice(0, 900) + '…' : receipt.layout_text

    section.section-card
      h2 Smart mappings
      if mappingMatches && mappingMatches.length
        p.section-subtitle Apply a matched rule to auto-fill the form. Rules are sorted by priority, then recency.
        .mapping-list
          each rule in mappingMatches
            - const isActive = appliedRuleId && appliedRuleId === rule.id;
            button.mapping-pill(type="button", data-apply-mapping=rule.id, class=isActive ? 'is-active' : '', data-target=rule.target)
              .pill-header
                span.pill-name= rule.name
                span.pill-target= rule.target === 'credit' ? 'Credit card' : 'Budget'
              if rule.description
                p.pill-description= rule.description
              .pill-meta
                span Priority #{rule.priority || 0}
                if rule.conditions && rule.conditions.length
                  span · #{rule.conditions.length} conditions matched
        button.btn.btn-link.btn-sm.text-muted(type="button", data-reset-mapping) Reset to defaults
        p.js-mapping-status.mapping-status
      else
        p.text-muted No mapping rules matched this receipt. Defaults are pre-filled from the receipt data.

    section.section-card
      h2 Create entry
      p.section-subtitle Choose a destination ledger, confirm the pre-filled fields, and submit. The tab will close after a successful save.
      form.js-receipt-entry-form(action=`/receipt/add-entry/${receipt._id.toString()}`, method="post", autocomplete="off")
        input(type="hidden", name="entryType", value=entryMode || 'budget')
        .form-grid
          .form-field
            label(for="amount") Amount
            input#amount.form-control(type="number", step="0.01", name="amount", value=amountValue, required)
          .form-field
            label(for="transaction_business") Business
            input#transaction_business.form-control(type="text", name="transaction_business", value=budgetPrefill && budgetPrefill.transaction_business ? budgetPrefill.transaction_business : (receipt.business_name || ''), placeholder="Store or vendor name", data-required-when="budget", list="receipt-business-suggestions")
        .entry-mode-toggle
          button(type="button", data-mode-toggle="budget", class=entryMode === 'budget' ? 'is-active' : '') Budget transaction
          button(type="button", data-mode-toggle="credit", class=entryMode === 'credit' ? 'is-active' : '') Credit card transaction

        .ledger-form(data-section="budget", class=entryMode === 'credit' ? 'is-hidden' : '')
          h3 Budget details
          .form-grid
            .form-field
              label(for="date") Transaction date
              input#date.form-control(type="date", name="date", value=budgetDateValue, data-required-when="budget")
            .form-field
              label(for="type") Type
              select#type.form-select(name="type", data-required-when="budget")
                option(value="")
                each t in typeOptions
                  - const label = typeof t === 'string' ? t.charAt(0).toUpperCase() + t.slice(1) : t;
                  option(value=t, selected=budgetPrefill && budgetPrefill.type === t)= label
            .form-field
              label(for="from_account") From (payer)
              select#from_account.form-select(name="from_account", data-required-when="budget")
                option(value="") Select payer
                option(value="EXT", selected=budgetPrefill && budgetPrefill.from_account === 'EXT') External (EXT)
                each acc in accounts || []
                  - const accId = acc._id ? acc._id.toString() : '';
                  option(value=accId, selected=budgetPrefill && budgetPrefill.from_account === accId)= acc.name
            .form-field
              label(for="to_account") To (receiver)
              select#to_account.form-select(name="to_account", data-required-when="budget")
                option(value="") Select receiver
                option(value="EXT", selected=budgetPrefill && budgetPrefill.to_account === 'EXT') External (EXT)
                each acc in accounts || []
                  - const accId2 = acc._id ? acc._id.toString() : '';
                  option(value=accId2, selected=budgetPrefill && budgetPrefill.to_account === accId2)= acc.name
            .form-field
              label(for="categories") Categories
              input#categories.form-control(type="text", name="categories", value=budgetPrefill && budgetPrefill.categories || '', placeholder="e.g. 63a... | 63b...", data-required-when="budget", list="category-list")
              small.text-muted Select a category to insert it, or type your own mix.
              select.form-select.form-select-sm.mt-1(onchange="if(this.value){document.getElementById('categories').value=this.value;}")
                option(value="") Choose category to insert
                each cat in categories || []
                  - const catId = cat._id ? cat._id.toString() : '';
                  option(value=catId)= cat.title
            .form-field
              label(for="tags") Tags
              input#tags.form-control(type="text", name="tags", value=budgetPrefill && budgetPrefill.tags || '', placeholder="Optional tags, pipe-separated", data-token-autocomplete="tags", autocomplete="off")
            .form-field
              label(for="from_fee") From fee
              input#from_fee.form-control(type="number", step="0.01", name="from_fee", value=budgetPrefill && budgetPrefill.from_fee !== undefined ? budgetPrefill.from_fee : 0, data-required-when="budget")
            .form-field
              label(for="to_fee") To fee
              input#to_fee.form-control(type="number", step="0.01", name="to_fee", value=budgetPrefill && budgetPrefill.to_fee !== undefined ? budgetPrefill.to_fee : 0, data-required-when="budget")

        .ledger-form(data-section="credit", class=entryMode === 'credit' ? '' : 'is-hidden')
          h3 Credit card details
          .form-grid
            .form-field
              label(for="transactionDate") Transaction date
              input#transactionDate.form-control(type="date", name="transactionDate", value=creditDateValue, data-required-when="credit")
            .form-field
              label(for="cardId") Card
              select#cardId.form-select(name="cardId", data-required-when="credit")
                option(value="") Select a card
                each card in creditCards || []
                  - const cardValue = card.id ? card.id.toString() : (card._id ? card._id.toString() : '');
                  option(value=cardValue, selected=creditPrefill && creditPrefill.cardId === cardValue)= card.name
            .form-field
              label(for="label") Description
              input#label.form-control(type="text", name="label", value=creditPrefill && creditPrefill.label || (receipt.business_name || ''), placeholder="Statement label", data-required-when="credit", list="receipt-credit-label-suggestions")
            .form-field
              .form-check.mt-4
                input#external.form-check-input(type="checkbox", name="external", value="true", checked=creditPrefill && creditPrefill.external)
                label.form-check-label(for="external") External (earns points)
            .form-field
              label(for="externalMultiplier") External multiplier (%)
              input#externalMultiplier.form-control(type="number", step="0.1", min="0", name="externalMultiplier", value=creditPrefill && creditPrefill.externalMultiplier !== undefined ? creditPrefill.externalMultiplier : 1, data-required-when="credit")

        .form-actions
          button.btn.btn-primary(type="submit") Save entry
          a.btn.btn-outline-secondary(href="/receipt") Back
          small.text-muted.ms-2 The tab will attempt to close itself after a successful save.

  datalist#category-list
    each cat in categories || []
      - const catId = cat._id ? cat._id.toString() : '';
      option(value=catId)= cat.title
  datalist#receipt-business-suggestions
    each business in businessSuggestions
      option(value=business)
  datalist#receipt-credit-label-suggestions
    each label in creditLabelSuggestions
      option(value=label)

block script
  - const scriptAutocompleteSuggestions = typeof receiptAutocomplete !== 'undefined' && receiptAutocomplete ? receiptAutocomplete : {};
  - const scriptTagSuggestions = Array.isArray(scriptAutocompleteSuggestions.tags) ? scriptAutocompleteSuggestions.tags : [];
  - const safeJson = (value) => JSON.stringify(value).replace(/</g, '\\u003c');
  script(type="application/json", id="mapping-data")!= JSON.stringify(mappingMatches || [])
  script(type="application/json", id="prefill-data")!= JSON.stringify({ defaults: { budgetPrefill: defaultBudgetPrefill || {}, creditPrefill: defaultCreditPrefill || {}, entryMode: defaultEntryMode || 'budget' }, applied: { budgetPrefill: budgetPrefill || {}, creditPrefill: creditPrefill || {}, entryMode: entryMode || 'budget', appliedRuleId: appliedRuleId || null } })
  script(type="application/json", id="autocomplete-data")!= safeJson({ tags: scriptTagSuggestions })
  script.
    (function () {
      const parseJson = function (id, fallback) {
        const el = document.getElementById(id);
        if (!el) return fallback;
        try {
          return JSON.parse(el.textContent);
        } catch (err) {
          return fallback;
        }
      };
      const mapping = parseJson('mapping-data', []);
      const prefill = parseJson('prefill-data', {
        defaults: { budgetPrefill: {}, creditPrefill: {}, entryMode: 'budget' },
        applied: { budgetPrefill: {}, creditPrefill: {}, entryMode: 'budget', appliedRuleId: null },
      });
      const autocompleteData = parseJson('autocomplete-data', { tags: [] });
      const form = document.querySelector('.js-receipt-entry-form');
      if (!form) return;

      const entryTypeInput = form.querySelector('input[name="entryType"]');
      const budgetSection = form.querySelector('[data-section="budget"]');
      const creditSection = form.querySelector('[data-section="credit"]');
      const budgetRequired = form.querySelectorAll('[data-required-when="budget"]');
      const creditRequired = form.querySelectorAll('[data-required-when="credit"]');
      const mappingStatus = document.querySelector('.js-mapping-status');
      const defaultState = {
        budgetPrefill: prefill.defaults && prefill.defaults.budgetPrefill ? { ...prefill.defaults.budgetPrefill } : {},
        creditPrefill: prefill.defaults && prefill.defaults.creditPrefill ? { ...prefill.defaults.creditPrefill } : {},
        entryMode: prefill.defaults && prefill.defaults.entryMode === 'credit' ? 'credit' : 'budget',
        appliedRuleId: null,
      };
      const serverAppliedState = {
        budgetPrefill: prefill.applied && prefill.applied.budgetPrefill ? { ...prefill.applied.budgetPrefill } : {},
        creditPrefill: prefill.applied && prefill.applied.creditPrefill ? { ...prefill.applied.creditPrefill } : {},
        entryMode: prefill.applied && prefill.applied.entryMode === 'credit' ? 'credit' : defaultState.entryMode,
        appliedRuleId: prefill.applied && prefill.applied.appliedRuleId ? prefill.applied.appliedRuleId : null,
      };

      const toggleRequired = function (nodes, enabled) {
        nodes.forEach(function (node) {
          if (!node) return;
          if (enabled) node.setAttribute('required', 'required');
          else node.removeAttribute('required');
          if (enabled) node.removeAttribute('disabled');
          else node.setAttribute('disabled', 'disabled');
        });
      };

      const setMode = function (mode) {
        const normalized = mode === 'credit' ? 'credit' : 'budget';
        entryTypeInput.value = normalized;
        if (budgetSection) budgetSection.classList.toggle('is-hidden', normalized !== 'budget');
        if (creditSection) creditSection.classList.toggle('is-hidden', normalized !== 'credit');
        toggleRequired(budgetRequired, normalized === 'budget');
        toggleRequired(creditRequired, normalized === 'credit');
        document.querySelectorAll('[data-mode-toggle]').forEach(function (btn) {
          btn.classList.toggle('is-active', btn.getAttribute('data-mode-toggle') === normalized);
        });
      };

      const toBoolean = function (value) {
        if (typeof value === 'string') {
          const normalized = value.trim().toLowerCase();
          return normalized === 'true'
            || normalized === '1'
            || normalized === 'yes'
            || normalized === 'on'
            || normalized === 'y'
            || normalized === 't';
        }
        return Boolean(value);
      };

      const mergePrefill = function (base, override) {
        const merged = base ? { ...base } : {};
        const source = override && typeof override === 'object' ? override : {};
        Object.keys(source).forEach(function (key) {
          const value = source[key];
          if (value === undefined || value === null) return;
          if (typeof value === 'string' && value === '') return;
          merged[key] = value;
        });
        return merged;
      };

      const setValue = function (selector, value) {
        if (value === undefined || value === null) return;
        const el = form.querySelector(selector);
        if (el) {
          el.removeAttribute('disabled');
          el.value = value;
        }
      };

      const setChecked = function (selector, checked) {
        const el = form.querySelector(selector);
        if (!el) return;
        const normalized = Boolean(checked);
        el.checked = normalized;
        el.defaultChecked = normalized;
        if (normalized) el.setAttribute('checked', 'checked');
        else el.removeAttribute('checked');
      };

      const setupTokenAutocomplete = function (input, suggestions) {
        const source = Array.isArray(suggestions)
          ? suggestions.map(function (item) { return typeof item === 'string' ? item.trim() : ''; }).filter(Boolean)
          : [];
        if (!input || !source.length) return;

        const field = input.closest('.form-field') || input.parentNode;
        const menu = document.createElement('div');
        let matches = [];
        let activeIndex = -1;

        field.classList.add('receipt-autocomplete-field');
        menu.className = 'receipt-autocomplete-menu';
        menu.hidden = true;
        menu.setAttribute('role', 'listbox');
        field.appendChild(menu);
        input.setAttribute('aria-autocomplete', 'list');
        input.setAttribute('aria-expanded', 'false');

        const normalize = function (value) {
          return String(value || '').trim().toLowerCase();
        };

        const getParts = function () {
          const value = input.value || '';
          const cursor = typeof input.selectionStart === 'number' ? input.selectionStart : value.length;
          const parts = [];
          let start = 0;

          for (let i = 0; i < value.length; i += 1) {
            if (value[i] === '|' || value[i] === ',') {
              parts.push({ text: value.slice(start, i), start: start, end: i });
              start = i + 1;
            }
          }
          parts.push({ text: value.slice(start), start: start, end: value.length });

          let index = parts.findIndex(function (part) {
            return cursor >= part.start && cursor <= part.end + 1;
          });
          if (index < 0) index = parts.length - 1;

          return { parts: parts, index: index };
        };

        const buildMatches = function () {
          const info = getParts();
          const current = info.parts[info.index] ? info.parts[info.index].text.trim() : '';
          const currentKey = normalize(current);
          const used = new Set();

          info.parts.forEach(function (part, index) {
            if (index === info.index) return;
            const key = normalize(part.text);
            if (key) used.add(key);
          });

          return source.filter(function (suggestion) {
            const key = normalize(suggestion);
            if (!key || used.has(key)) return false;
            return !currentKey || key.includes(currentKey);
          }).slice(0, 8);
        };

        const hideMenu = function () {
          menu.hidden = true;
          input.setAttribute('aria-expanded', 'false');
          activeIndex = -1;
        };

        const setActive = function (index) {
          activeIndex = index;
          Array.from(menu.children).forEach(function (child, childIndex) {
            child.classList.toggle('is-active', childIndex === activeIndex);
          });
        };

        const selectSuggestion = function (value) {
          const info = getParts();
          const tokens = info.parts.map(function (part) { return part.text.trim(); });
          const output = [];
          const seen = new Set();
          let selectedOutputIndex = -1;

          tokens[info.index] = value;
          tokens.forEach(function (token, index) {
            const normalized = normalize(token);
            if (!normalized) return;
            if (seen.has(normalized)) {
              if (index === info.index) {
                selectedOutputIndex = output.findIndex(function (existing) {
                  return normalize(existing) === normalized;
                });
              }
              return;
            }
            if (index === info.index) selectedOutputIndex = output.length;
            seen.add(normalized);
            output.push(token);
          });

          if (selectedOutputIndex < 0) {
            selectedOutputIndex = output.length;
            output.push(value);
          }

          input.value = output.join(' | ');
          let cursor = output.slice(0, selectedOutputIndex + 1).join(' | ').length;
          if (selectedOutputIndex === output.length - 1) {
            input.value += ' | ';
            cursor = input.value.length;
          }
          if (typeof input.setSelectionRange === 'function') {
            input.setSelectionRange(cursor, cursor);
          }
          input.dispatchEvent(new Event('change', { bubbles: true }));
          renderMenu();
        };

        var renderMenu = function () {
          if (input.disabled) {
            hideMenu();
            return;
          }

          matches = buildMatches();
          menu.innerHTML = '';
          if (!matches.length) {
            hideMenu();
            return;
          }

          matches.forEach(function (suggestion, index) {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'receipt-autocomplete-option';
            button.textContent = suggestion;
            button.setAttribute('role', 'option');
            button.addEventListener('mousedown', function (event) {
              event.preventDefault();
              selectSuggestion(suggestion);
            });
            button.addEventListener('mouseenter', function () {
              setActive(index);
            });
            menu.appendChild(button);
          });

          menu.hidden = false;
          input.setAttribute('aria-expanded', 'true');
          setActive(Math.min(Math.max(activeIndex, 0), matches.length - 1));
        };

        input.addEventListener('input', renderMenu);
        input.addEventListener('focus', renderMenu);
        input.addEventListener('click', renderMenu);
        input.addEventListener('blur', function () {
          window.setTimeout(hideMenu, 120);
        });
        input.addEventListener('keydown', function (event) {
          if (menu.hidden) {
            if (event.key === 'ArrowDown') renderMenu();
            return;
          }

          if (event.key === 'ArrowDown') {
            event.preventDefault();
            setActive((activeIndex + 1) % matches.length);
          } else if (event.key === 'ArrowUp') {
            event.preventDefault();
            setActive((activeIndex - 1 + matches.length) % matches.length);
          } else if (event.key === 'Enter') {
            event.preventDefault();
            selectSuggestion(matches[activeIndex] || matches[0]);
          } else if (event.key === 'Tab' && activeIndex >= 0) {
            event.preventDefault();
            selectSuggestion(matches[activeIndex]);
          } else if (event.key === 'Escape') {
            hideMenu();
          }
        });
      };

      const applyBudgetPrefill = function (payload) {
        if (!payload) return;
        setValue('input[name="date"]', payload.date);
        setValue('select[name="from_account"]', payload.from_account);
        setValue('select[name="to_account"]', payload.to_account);
        setValue('input[name="categories"]', payload.categories);
        setValue('input[name="tags"]', payload.tags);
        setValue('select[name="type"]', payload.type);
        setValue('input[name="from_fee"]', payload.from_fee);
        setValue('input[name="to_fee"]', payload.to_fee);
        setValue('input[name="transaction_business"]', payload.transaction_business);
        setValue('input[name="amount"]', payload.amount);
      };

      const applyCreditPrefill = function (payload) {
        if (!payload) return;
        setValue('input[name="transactionDate"]', payload.transactionDate);
        setValue('select[name="cardId"]', payload.cardId);
        setValue('input[name="label"]', payload.label);
        setValue('input[name="externalMultiplier"]', payload.externalMultiplier);
        setValue('input[name="amount"]', payload.amount);
        setChecked('input[name="external"]', toBoolean(payload.external));
      };

      const updateActiveRule = function (ruleId) {
        document.querySelectorAll('[data-apply-mapping]').forEach(function (btn) {
          btn.classList.toggle('is-active', Boolean(ruleId) && btn.getAttribute('data-apply-mapping') === ruleId);
        });
      };

      const buildStateForRule = function (rule) {
        if (!rule) {
          return {
            budgetPrefill: { ...defaultState.budgetPrefill },
            creditPrefill: { ...defaultState.creditPrefill },
            entryMode: defaultState.entryMode,
            appliedRuleId: null,
          };
        }
        return {
          budgetPrefill: rule.target === 'budget'
            ? mergePrefill(defaultState.budgetPrefill, rule.budgetPrefill)
            : { ...defaultState.budgetPrefill },
          creditPrefill: rule.target === 'credit'
            ? mergePrefill(defaultState.creditPrefill, rule.creditPrefill)
            : { ...defaultState.creditPrefill },
          entryMode: rule.target === 'credit' ? 'credit' : 'budget',
          appliedRuleId: rule.id || null,
        };
      };

      const applyState = function (state) {
        const nextState = state || defaultState;
        applyBudgetPrefill(nextState.budgetPrefill || {});
        applyCreditPrefill(nextState.creditPrefill || {});
        setMode(nextState.entryMode || 'budget');
        updateActiveRule(nextState.appliedRuleId || null);
      };

      const applyMapping = function (ruleId) {
        const rule = mapping.find(function (m) { return m.id === ruleId; });
        if (!rule) return;
        applyState(buildStateForRule(rule));
        if (mappingStatus) mappingStatus.textContent = "Applied rule: " + rule.name;
      };

      document.querySelectorAll('[data-apply-mapping]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          applyMapping(btn.getAttribute('data-apply-mapping'));
        });
      });

      const resetToDefaults = function () {
        applyState(defaultState);
        if (mappingStatus) mappingStatus.textContent = 'Reset to receipt defaults.';
      };

      const resetBtn = document.querySelector('[data-reset-mapping]');
      if (resetBtn) {
        resetBtn.addEventListener('click', resetToDefaults);
      }

      document.querySelectorAll('[data-mode-toggle]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          setMode(btn.getAttribute('data-mode-toggle'));
        });
      });

      setupTokenAutocomplete(
        form.querySelector('[data-token-autocomplete="tags"]'),
        autocompleteData.tags || []
      );

      // Apply initial state
      const initialRule = serverAppliedState.appliedRuleId
        ? mapping.find(function (rule) { return rule.id === serverAppliedState.appliedRuleId; })
        : null;
      const initialState = initialRule
        ? buildStateForRule(initialRule)
        : {
          budgetPrefill: mergePrefill(defaultState.budgetPrefill, serverAppliedState.budgetPrefill),
          creditPrefill: mergePrefill(defaultState.creditPrefill, serverAppliedState.creditPrefill),
          entryMode: serverAppliedState.entryMode || defaultState.entryMode,
          appliedRuleId: serverAppliedState.appliedRuleId || null,
        };

      const applyInitialState = function () {
        applyState(initialState);
        if (mappingStatus) {
          if (initialRule) mappingStatus.textContent = "Applied rule: " + initialRule.name;
          else if (mapping && mapping.length) mappingStatus.textContent = 'Using receipt defaults.';
        }
      };

      applyInitialState();
      window.requestAnimationFrame(applyInitialState);
      window.setTimeout(applyInitialState, 0);
      window.addEventListener('pageshow', applyInitialState);
    }());
