extends layout

block content
  h1 Quick Notes Review
  .d-flex.flex-column.flex-md-row.justify-content-md-between.align-items-md-center.gap-2.mb-3
    .btn-group(role='group' aria-label='Quick note sort order')
      button#sortNewerFirst.btn.btn-outline-primary.active(type='button' data-sort-mode='newer' aria-pressed='true') Newer first
      button#sortCloserFirst.btn.btn-outline-primary(type='button' data-sort-mode='closer' aria-pressed='false') Closer first
    p#quickNotesSortStatus.text-muted.mb-0 Sorted newer first.
  #quickNotes
  button#deleteOldNotes.btn.btn-danger Delete notes older than 30 days
  hr
  h2 Saved locations 
  each l in locations
    a.btn.btn-link(href=`/quicknote/navigate_to_location/${l.location.coordinates[1]}/${l.location.coordinates[0]}`)= l.name 
  script(src="/js/quick_note.js") 
