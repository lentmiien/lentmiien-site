extends layout

block content
  .receipt-page
    h1 Receipt Inbox
    p.page-intro Collect, review, and act on purchase receipts in one minimal workspace.
    if error
      .alert.alert-danger(role='alert')= error
    p
      a.btn.btn-outline-secondary.btn-sm(href='/receipt/mappings') Manage mapping rules
    section.section-card.upload-card
      h2 Upload a receipt
      p.section-subtitle Supported formats: JPEG, PNG, WebP, AVIF, GIF, SVG, TIFF.
      form(action='/receipt/upload_receipt', method='post', enctype='multipart/form-data')
        label(for='imgs') Select receipt image files
        .input-group
          input#imgs.form-control(type='file', name='imgs', multiple)
          input.btn.btn-primary(type='submit', value='Upload')
    section.section-card.history-card
      .history-controls
        .history-title-group
          h2 History
          include includes/receipt_history_summary
        form#receipt-history-filter-form.history-filter-form(action='/receipt', method='get', data-partial-url='/receipt/history')
          label(for='receipt-history-filter') Show
          select#receipt-history-filter.form-select(name='history')
            each option in historyOptions
              option(value=option.value, selected=option.value === selectedHistory)= option.label
          noscript
            button.btn.btn-secondary(type='submit') Apply
      include includes/receipt_history_content

block script
  script(src='/js/receipt.js', defer)
