extends ../layout

block styles
  link(rel='stylesheet', href='/css/codex.css')

block content
  - const state = codexState || {};
  - const session = state.session || {};
  - const workspace = state.workspace || {};
  - const turns = state.turns || [];
  - const requestProfiles = state.requestProfiles || [];
  - const promptTemplates = state.promptTemplates || [];
  - const stats = state.stats || {};
  - const tokenTypes = ['input', 'cached', 'output', 'reasoning'];
  - const tokenLabels = { input: 'Input', cached: 'Cached', output: 'Output', reasoning: 'Reasoning' };
  - const config = state.config || {};
  - const maxPromptChars = Number(config.maxPromptChars) > 0 ? Number(config.maxPromptChars) : 20000;
  - const fmt = (value) => value ? new Date(value).toLocaleString() : '-';
  - const num = (value) => Number.isFinite(Number(value)) ? Math.round(Number(value)).toLocaleString() : '0';
  - const money = (value) => '$' + (Number(value) || 0).toFixed(4);
  - const duration = (ms) => Number.isFinite(ms) ? `${Math.round(ms / 1000)}s` : '-';
  - const statusClass = (status) => `codex-status codex-status--${String(status || '').replace(/_/g, '-')}`;
  section.codex-page(data-codex-page='session', data-session-id=session.id)
    .codex-shell
      .codex-topbar
        div
          a.codex-back-link(href='/codex') Back to Codex
          h1.codex-title= session.title || 'Codex session'
          p.codex-subtitle
            span= workspace.name || 'Workspace'
            span= ' / '
            span= session.codexThreadId ? session.codexThreadId : 'waiting for Codex session id'
        .codex-topbar__actions
          a.codex-button.codex-button--secondary(href='/codex/templates') Prompt Library
          a.codex-button.codex-button--secondary(href=`/codex/turns/${session.lastTurnId}`) Latest turn
          button.codex-button.codex-button--secondary(type='button', data-action='archive-session', data-session-id=session.id) Archive

      .codex-session-meta
        span(class=statusClass(session.status))= session.status
        span= 'Turns: ' + (session.turnCount || turns.length)
        span= 'Updated: ' + fmt(session.updatedAt)

      section.codex-panel.codex-session-stats(data-codex-session-stats)
        .codex-panel__header
          h2 Session Totals
          span.codex-chip= money(stats.cost)
        .codex-stat-grid.codex-stat-grid--compact
          .codex-stat-card
            small Total Time
            strong= duration(stats.totalDurationMs)
            span= 'Elapsed ' + duration(stats.elapsedMs)
          .codex-stat-card
            small Turns
            strong= num(stats.turnCount || turns.length)
            span= num(stats.completedTurnCount) + ' timed'
          each type in tokenTypes
            .codex-stat-card
              small= tokenLabels[type]
              strong= num(stats.tokens && stats.tokens[type])
              span tokens

      .codex-timeline(data-codex-timeline)
        if turns.length
          each turn in turns
            article.codex-turn-card(data-turn-id=turn.id)
              .codex-turn-card__header
                div
                  span(class=statusClass(turn.status))= turn.status
                  strong= 'Turn ' + turn.sequence
                  span= turn.kind.replace(/_/g, ' ')
                .codex-turn-card__actions
                  a.codex-small-link(href=`/codex/turns/${turn.id}`) Open
                  if turn.status === 'queued' || turn.status === 'running'
                    button.codex-small-button(type='button', data-action='cancel-turn', data-turn-id=turn.id) Cancel
                  if ['failed', 'timed_out', 'cancelled', 'blocked'].includes(turn.status)
                    button.codex-small-button(type='button', data-action='retry-turn', data-turn-id=turn.id) Retry
              .codex-turn-meta
                span= workspace.name || '-'
                span= turn.permissionMode
                if turn.requestProfileName
                  span= 'Profile ' + turn.requestProfileName
                if turn.model
                  span= 'Model ' + turn.model
                if turn.reasoningEffort
                  span= 'Reasoning ' + turn.reasoningEffort
                span= 'Queued ' + fmt(turn.queuedAt)
                span= 'Duration ' + duration(turn.durationMs)
                span= 'Turn cost ' + money(turn.costEstimate && turn.costEstimate.total)
              if turn.status === 'running'
                .codex-live-activity(data-turn-activity=turn.id, data-activity-state='live', aria-label='Live Codex process activity')
                  span.codex-live-activity__signal(aria-hidden='true')
                    span
                    span
                    span
                  span.codex-live-activity__copy
                    strong(data-activity-heading) Codex is working
                    span(data-activity-summary) Waiting for the first process detail…
                  span.codex-visually-hidden(data-activity-announcement, aria-live='polite', aria-atomic='true')
              .codex-token-strip
                each type in tokenTypes
                  span.codex-token-pill
                    small= tokenLabels[type]
                    strong= num(turn.tokenUsage && turn.tokenUsage[type])
              .codex-transcript
                .codex-transcript__block
                  h3 Prompt
                  pre= turn.prompt
                .codex-transcript__block
                  h3 Response
                  if turn.finalResponse
                    pre= turn.finalResponse
                  else if turn.errorMessage
                    p.codex-error-text= turn.errorMessage
                  else
                    p.codex-empty Response pending.
              .codex-event-panel
                - const detailsId = `codex-events-${turn.id}`;
                button.codex-small-button(type='button', data-action='toggle-events', data-turn-id=turn.id, aria-controls=detailsId, aria-expanded='false')= turn.eventCount ? `Process details (${turn.eventCount})` : 'Process details'
                .codex-events(id=detailsId, hidden, data-events-for=turn.id)
        else
          p.codex-empty No turns found.

      section.codex-panel.codex-followup-panel
        .codex-panel__header
          h2 Follow-up
          span.codex-chip= session.codexThreadId ? 'Ready' : 'Waiting'
        if session.codexThreadId
          form#codex-followup-form.codex-form(data-session-id=session.id, data-codex-prompt-form)
            .codex-mode-group(role='radiogroup', aria-label='Follow-up mode')
              label.codex-mode-option
                input(type='radio', name='mode', value='question', checked)
                span Question
              label.codex-mode-option
                input(type='radio', name='mode', value='action')
                span Action
              label.codex-mode-option
                input(type='radio', name='mode', value='git_commit_push')
                span Git commit &amp; push
            .codex-field
              label(for='codex-followup-permission') Permission
              select#codex-followup-permission(name='permissionMode')
                option(value='auto') Auto
                option(value='read-only') Read only
                option(value='workspace-write') Workspace write
                option(value='yolo') Yolo (dangerous)
            .codex-field.codex-yolo-confirm(hidden)
              label.codex-check
                input(type='checkbox', name='confirmYolo', value='1')
                span Confirm yolo mode for this turn
            .codex-field
              label(for='codex-followup-profile') Profile
              select#codex-followup-profile(name='requestProfileId')
                if requestProfiles.length
                  each profile in requestProfiles
                    - const detailParts = [];
                    - if (profile.model) detailParts.push(profile.model);
                    - if (profile.reasoningEffort) detailParts.push(profile.reasoningEffort);
                    - if (profile.codexProfile) detailParts.push('config ' + profile.codexProfile);
                    option(value=profile.id, selected=profile.id === 'default')= detailParts.length ? `${profile.name} - ${detailParts.join(' / ')}` : profile.name
                else
                  option(value='') Default
            .codex-field
              .codex-field-label-row
                label(for='codex-followup-prompt') Prompt
                a.codex-small-link(href='/codex/templates') Manage templates
              select#codex-followup-template(data-codex-template-select, data-prompt-target='codex-followup-prompt', aria-label='Prompt template', disabled=!promptTemplates.length)
                option(value='')= promptTemplates.length ? 'Select a template…' : 'No templates available for this workspace'
                each template in promptTemplates
                  option(value=template.id)= template.name
              small#codex-followup-template-help.codex-field-help(data-codex-template-help)= promptTemplates.length ? 'Choose a template to copy it into the prompt.' : 'Save a global or workspace-specific prompt in the Prompt Library.'
              textarea#codex-followup-prompt(
                name='prompt',
                rows='5',
                maxlength=maxPromptChars,
                required,
                data-codex-prompt-input,
                data-max-characters=maxPromptChars,
                aria-describedby='codex-followup-template-help codex-followup-character-count'
              )
              small#codex-followup-character-count.codex-character-count(data-codex-character-count)= `0 / ${maxPromptChars.toLocaleString()} characters`
            .codex-actions
              button.codex-button(type='submit', data-codex-prompt-submit) Submit follow-up
              span#codex-followup-status.codex-form-status(aria-live='polite')
        else
          p.codex-empty Follow-up is unavailable until the first turn starts and Codex reports a session id.

block script
  script#codex-page-data(type='application/json')!= codexStateJson
  script(src='/js/codex.js', defer)
