extends ../layout

block styles
  link(rel='stylesheet', href='/css/codex.css')

block content
  - const state = codexState || {};
  - const turn = state.turn || {};
  - const session = state.session || {};
  - const workspace = state.workspace || {};
  - const tokenTypes = ['input', 'cached', 'output', 'reasoning'];
  - const tokenLabels = { input: 'Input', cached: 'Cached', output: 'Output', reasoning: 'Reasoning' };
  - const fmt = (value) => value ? new Date(value).toLocaleString() : '-';
  - const num = (value) => Number.isFinite(Number(value)) ? Math.round(Number(value)).toLocaleString() : '0';
  - const money = (value) => '$' + (Number(value) || 0).toFixed(4);
  - const duration = (ms) => Number.isFinite(ms) ? `${Math.round(ms / 1000)}s` : '-';
  - const statusClass = (status) => `codex-status codex-status--${String(status || '').replace(/_/g, '-')}`;
  section.codex-page(data-codex-page='turn', data-turn-id=turn.id)
    .codex-shell
      .codex-topbar
        div
          a.codex-back-link(href=`/codex/sessions/${session.id}`) Back to session
          h1.codex-title= `Turn ${turn.sequence || ''}`
          p.codex-subtitle
            span= session.title || 'Codex session'
            span= ' / '
            span= workspace.name || 'Workspace'
        .codex-topbar__actions(data-turn-actions)
          if turn.status === 'queued' || turn.status === 'running'
            button.codex-button.codex-button--secondary(type='button', data-action='cancel-turn', data-turn-id=turn.id) Cancel
          if ['failed', 'timed_out', 'cancelled', 'blocked'].includes(turn.status)
            button.codex-button.codex-button--secondary(type='button', data-action='retry-turn', data-turn-id=turn.id) Retry

      .codex-turn-detail(data-codex-turn-detail)
        .codex-panel
          .codex-panel__header
            h2 Status
            span(class=statusClass(turn.status))= turn.status
          .codex-live-activity-slot(data-live-activity-slot)
            if turn.status === 'running'
              .codex-live-activity(data-turn-activity=turn.id, data-activity-state='live', aria-label='Live Codex process activity')
                span.codex-live-activity__signal(aria-hidden='true')
                  span
                  span
                  span
                span.codex-live-activity__copy
                  strong(data-activity-heading) Codex is working
                  span(data-activity-summary) Waiting for the first process detail…
                span.codex-visually-hidden(data-activity-announcement, aria-live='polite', aria-atomic='true')
          .codex-detail-grid
            div
              small Workspace
              strong= workspace.name || '-'
            div
              small Mode
              strong= turn.kind ? turn.kind.replace(/_/g, ' ') : '-'
            div
              small Permission
              strong= turn.permissionMode || '-'
            div
              small Profile
              strong= turn.requestProfileName || '-'
            div
              small Model
              strong= turn.model || '-'
            div
              small Reasoning
              strong= turn.reasoningEffort || '-'
            div
              small Queued
              strong= fmt(turn.queuedAt)
            div
              small Started
              strong= fmt(turn.startedAt)
            div
              small Completed
              strong= fmt(turn.completedAt)
            div
              small Duration
              strong= duration(turn.durationMs)
            div
              small Turn Input Tokens
              strong= num(turn.tokenUsage && turn.tokenUsage.input)
            div
              small Turn Cached Tokens
              strong= num(turn.tokenUsage && turn.tokenUsage.cached)
            div
              small Turn Output Tokens
              strong= num(turn.tokenUsage && turn.tokenUsage.output)
            div
              small Turn Reasoning Tokens
              strong= num(turn.tokenUsage && turn.tokenUsage.reasoning)
            div
              small Turn Estimated Cost
              strong= money(turn.costEstimate && turn.costEstimate.total)
            div
              small Exit
              strong= turn.exitCode === null || turn.exitCode === undefined ? '-' : turn.exitCode
          if turn.errorMessage
            p.codex-error-text= turn.errorMessage

        .codex-transcript.codex-transcript--detail
          .codex-transcript__block
            h2 Prompt
            pre= turn.prompt
          .codex-transcript__block
            h2 Response
            if turn.finalResponse
              pre= turn.finalResponse
            else
              p.codex-empty Response pending.

        .codex-panel
          .codex-panel__header.codex-process-details__header
            h2 Process Details
            - const detailsAreLive = turn.status === 'running';
            - const detailsId = `codex-events-${turn.id}`;
            .codex-process-details__actions
              .codex-event-view-toggle(role='group', aria-label='Process detail view')
                button.codex-event-view-toggle__button(type='button', data-action='set-event-view', data-turn-id=turn.id, data-event-view-mode='all', aria-pressed='false') View all
                button.codex-event-view-toggle__button(type='button', data-action='set-event-view', data-turn-id=turn.id, data-event-view-mode='focused', aria-pressed='true') Agent messages & todos
              button.codex-small-button(type='button', data-action='toggle-events', data-turn-id=turn.id, aria-controls=detailsId, aria-expanded=detailsAreLive ? 'true' : 'false')= detailsAreLive ? 'Hide details' : (turn.eventCount ? `Show details (${turn.eventCount})` : 'Show details')
          .codex-events(id=detailsId, hidden=!detailsAreLive, data-events-for=turn.id, data-event-view-mode='focused')

block script
  script#codex-page-data(type='application/json')!= codexStateJson
  script(src='/js/codex.js', defer)
