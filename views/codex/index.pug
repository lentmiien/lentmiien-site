extends ../layout

block styles
  link(rel='stylesheet', href='/css/codex.css')

block content
  - const state = codexState || {};
  - const config = state.config || {};
  - const workspaces = state.workspaces || [];
  - const runningTurns = state.runningTurns || [];
  - const queuedTurns = state.queuedTurns || [];
  - const recentSessions = state.recentSessions || [];
  - const requestProfiles = state.requestProfiles || [];
  - const stats = state.stats || {};
  - const summary = stats.summary || {};
  - const pricing = state.pricing || {};
  - const tokenTypes = ['input', 'cached', 'output', 'reasoning'];
  - const tokenLabels = { input: 'Input', cached: 'Cached', output: 'Output', reasoning: 'Reasoning' };
  - const fmt = (value) => value ? new Date(value).toLocaleString() : '-';
  - const num = (value) => Number.isFinite(Number(value)) ? Math.round(Number(value)).toLocaleString() : '0';
  - const money = (value) => '$' + (Number(value) || 0).toFixed(4);
  - const pct = (value) => Number.isFinite(Number(value)) ? `${Number(value).toFixed(1)}%` : '-';
  - const duration = (ms) => Number.isFinite(Number(ms)) && Number(ms) > 0 ? (Number(ms) < 60000 ? `${Math.round(Number(ms) / 1000)}s` : `${Math.round(Number(ms) / 60000)}m`) : '-';
  - const statusClass = (status) => `codex-status codex-status--${String(status || '').replace(/_/g, '-')}`;
  section.codex-page(data-codex-page='dashboard')
    .codex-shell
      .codex-topbar
        div
          h1.codex-title Codex Workspace Assistant
          p.codex-subtitle Submit workspace-scoped Codex turns and review the stored session history.
        .codex-topbar__actions
          if admin
            a.codex-button.codex-button--secondary(href='/codex/profiles') Profiles
            a.codex-button.codex-button--secondary(href='/codex/workspaces') Workspaces
          button#codex-health-button.codex-button.codex-button--secondary(type='button', aria-haspopup='dialog', aria-controls='codex-health-modal') Health

      dialog#codex-health-modal.codex-health-modal(aria-labelledby='codex-health-title', aria-describedby='codex-health-summary')
        .codex-health-modal__header
          div
            h2#codex-health-title Codex Health
            p#codex-health-summary Current server, binary, and worker status.
          button.codex-health-modal__close(type='button', data-codex-health-close, aria-label='Close health dialog')
            span(aria-hidden='true') ×
        .codex-health-modal__body
          #codex-health-loading.codex-health-state(role='status', aria-live='polite', hidden)
            span.codex-health-spinner(aria-hidden='true')
            p Checking Codex health…
          #codex-health-error.codex-health-error(role='alert', hidden)
          #codex-health-content.codex-health-content(hidden)
        .codex-health-modal__footer
          button#codex-health-refresh.codex-button(type='button') Refresh
          button.codex-button.codex-button--secondary(type='button', data-codex-health-close) Close

      .codex-dashboard
        section.codex-panel.codex-panel--form
          .codex-panel__header
            h2 New Request
            span.codex-chip= workspaces.length + ' workspace' + (workspaces.length === 1 ? '' : 's')
          form#codex-new-session-form.codex-form
            .codex-field
              label(for='codex-workspace') Workspace
              select#codex-workspace(name='workspaceId', required, disabled=!workspaces.length)
                if workspaces.length
                  each workspace in workspaces
                    option(value=workspace.id)= workspace.name + ' - ' + workspace.rootPath
                else
                  option(value='') No workspaces configured
            .codex-mode-group(role='radiogroup', aria-label='Request mode')
              label.codex-mode-option
                input(type='radio', name='mode', value='question', checked)
                span Question
              label.codex-mode-option
                input(type='radio', name='mode', value='action')
                span Action
              label.codex-mode-option
                input(type='radio', name='mode', value='git_commit_push')
                span Git commit &amp; push
            .codex-field
              label(for='codex-permission') Permission
              select#codex-permission(name='permissionMode')
                option(value='auto') Auto
                option(value='read-only') Read only
                option(value='workspace-write') Workspace write
                option(value='yolo') Yolo (dangerous)
            .codex-field.codex-yolo-confirm(hidden)
              label.codex-check
                input(type='checkbox', name='confirmYolo', value='1')
                span Confirm yolo mode for this turn
            .codex-field
              label(for='codex-request-profile') Profile
              select#codex-request-profile(name='requestProfileId')
                if requestProfiles.length
                  each profile in requestProfiles
                    - const detailParts = [];
                    - if (profile.model) detailParts.push(profile.model);
                    - if (profile.reasoningEffort) detailParts.push(profile.reasoningEffort);
                    - if (profile.codexProfile) detailParts.push('config ' + profile.codexProfile);
                    option(value=profile.id, selected=profile.id === 'default')= detailParts.length ? `${profile.name} - ${detailParts.join(' / ')}` : profile.name
                else
                  option(value='') Default
            .codex-field
              label(for='codex-prompt') Prompt
              textarea#codex-prompt(name='prompt', rows='8', maxlength=config.maxPromptChars || 20000, required, placeholder='Ask a question or request a change...')
            .codex-actions
              button.codex-button(type='submit', disabled=!workspaces.length) Submit
              span#codex-new-session-status.codex-form-status(aria-live='polite')

        section.codex-panel
          .codex-panel__header
            h2 Running
            span.codex-chip(data-codex-running-count)= runningTurns.length
          .codex-list(data-codex-running-list)
            if runningTurns.length
              each turn in runningTurns
                article.codex-job-row(data-turn-id=turn.id)
                  .codex-job-row__main
                    span(class=statusClass(turn.status))= turn.status
                    a(href=`/codex/turns/${turn.id}`)= turn.workspace ? turn.workspace.name : 'Workspace'
                    small= 'Started ' + fmt(turn.startedAt)
                    .codex-live-activity(data-turn-activity=turn.id, data-activity-state='live', aria-label='Live Codex process activity')
                      span.codex-live-activity__signal(aria-hidden='true')
                        span
                        span
                        span
                      span.codex-live-activity__copy
                        strong(data-activity-heading) Codex is working
                        span(data-activity-summary) Waiting for the first process detail…
                      span.codex-visually-hidden(data-activity-announcement, aria-live='polite', aria-atomic='true')
                  button.codex-icon-button(type='button', data-action='cancel-turn', data-turn-id=turn.id, title='Cancel') Cancel
            else
              p.codex-empty No running requests.

        section.codex-panel
          .codex-panel__header
            h2 Queued
            span.codex-chip(data-codex-queued-count)= queuedTurns.length
          .codex-list(data-codex-queued-list)
            if queuedTurns.length
              each turn in queuedTurns
                article.codex-job-row
                  .codex-job-row__main
                    span(class=statusClass(turn.status))= turn.status
                    a(href=`/codex/turns/${turn.id}`)= turn.workspace ? turn.workspace.name : 'Workspace'
                    small= 'Queued ' + fmt(turn.queuedAt)
                  button.codex-icon-button(type='button', data-action='cancel-turn', data-turn-id=turn.id, title='Cancel') Cancel
            else
              p.codex-empty No queued requests.

        section.codex-panel.codex-panel--wide(data-codex-stats-summary)
          .codex-panel__header
            h2 Usage Overview
            span.codex-chip= stats.period ? stats.period.label : 'Last 3 months'
          .codex-stat-grid
            .codex-stat-card
              small Turns
              strong= num(summary.turnCount)
              span= num(summary.sessionCount) + ' sessions'
            .codex-stat-card
              small Tokens
              strong= num(summary.tokens && summary.tokens.total)
              span= 'Avg ' + num(summary.averageTokensPerTurn) + ' / turn'
            .codex-stat-card
              small Estimated Cost
              strong= money(summary.cost)
              span= pricing.currency || 'USD'
            .codex-stat-card
              small Avg Time
              strong= duration(summary.durationStats && summary.durationStats.avg)
              span= 'Max ' + duration(summary.durationStats && summary.durationStats.max)
            .codex-stat-card
              small Success
              strong= pct(summary.successRate)
              span= num(summary.successfulTurnCount) + ' completed'
            .codex-stat-card
              small Cache Share
              strong= pct(summary.cacheShare)
              span= 'Reasoning ' + pct(summary.reasoningShare)
          .codex-stats-split
            .codex-mini-stat
              h3 Completion Time
              dl.codex-inline-stats
                dt Min
                dd= duration(summary.durationStats && summary.durationStats.min)
                dt Avg
                dd= duration(summary.durationStats && summary.durationStats.avg)
                dt Median
                dd= duration(summary.durationStats && summary.durationStats.median)
                dt P95
                dd= duration(summary.durationStats && summary.durationStats.p95)
                dt Max
                dd= duration(summary.durationStats && summary.durationStats.max)
            .codex-mini-stat
              h3 Tokens / Turn
              dl.codex-inline-stats
                dt Min
                dd= num(summary.tokenStats && summary.tokenStats.min)
                dt Avg
                dd= num(summary.tokenStats && summary.tokenStats.avg)
                dt Median
                dd= num(summary.tokenStats && summary.tokenStats.median)
                dt P95
                dd= num(summary.tokenStats && summary.tokenStats.p95)
                dt Max
                dd= num(summary.tokenStats && summary.tokenStats.max)
            .codex-mini-stat
              h3 Type Distribution
              .codex-distribution-list
                if summary.kindDistribution && summary.kindDistribution.length
                  each item in summary.kindDistribution
                    div
                      span= item.label
                      strong= num(item.count) + ' / ' + pct(item.share)
                else
                  p.codex-empty No turn types yet.
            .codex-mini-stat
              h3 Status Distribution
              .codex-distribution-list
                if summary.statusDistribution && summary.statusDistribution.length
                  each item in summary.statusDistribution
                    div
                      span= item.label
                      strong= num(item.count) + ' / ' + pct(item.share)
                else
                  p.codex-empty No statuses yet.

        if admin
          section.codex-panel.codex-panel--full
            .codex-panel__header
              h2 Token Prices
              span.codex-chip USD / 1M tokens
            form#codex-pricing-form.codex-form.codex-form--pricing
              each type in tokenTypes
                .codex-field
                  label(for=`codex-price-${type}`)= tokenLabels[type]
                  input(id=`codex-price-${type}`, type='number', name=type, min='0', step='0.000001', value=(pricing.prices && pricing.prices[type]) || 0)
              .codex-actions
                button.codex-button(type='submit') Save Prices
                span#codex-pricing-status.codex-form-status(aria-live='polite')

        section.codex-panel.codex-panel--full
          .codex-panel__header
            h2 Monthly Tokens
            span.codex-chip Current + 2 previous
          .codex-table-wrap
            table.codex-table(data-codex-monthly-table)
              thead
                tr
                  th Month
                  th Turns
                  th Sessions
                  each type in tokenTypes
                    th= tokenLabels[type]
                  th Cost
              tbody(data-codex-monthly-body)
                if stats.months && stats.months.length
                  each month in stats.months
                    tr
                      td(data-label='Month')= month.label
                      td(data-label='Turns')= num(month.turnCount)
                      td(data-label='Sessions')= num(month.sessionCount)
                      each type in tokenTypes
                        td(data-label=tokenLabels[type])= num(month.tokens && month.tokens[type])
                      td(data-label='Cost')= money(month.cost)
                else
                  tr
                    td(colspan='8') No token usage recorded for the last 3 months.

        section.codex-panel.codex-panel--full
          .codex-panel__header
            h2 Workspace Activity
            span.codex-chip= (stats.workspaceActivity || []).length
          .codex-table-wrap
            table.codex-table(data-codex-workspace-table)
              thead
                tr
                  th Workspace
                  th Turns
                  th Sessions
                  th Input
                  th Cached
                  th Output
                  th Reasoning
                  th Avg Time
                  th Success
                  th Cost
              tbody(data-codex-workspace-body)
                if stats.workspaceActivity && stats.workspaceActivity.length
                  each workspaceStat in stats.workspaceActivity
                    tr
                      td(data-label='Workspace')
                        strong= workspaceStat.workspaceName || workspaceStat.label
                        if workspaceStat.rootPath
                          small= workspaceStat.rootPath
                      td(data-label='Turns')= num(workspaceStat.turnCount)
                      td(data-label='Sessions')= num(workspaceStat.sessionCount)
                      td(data-label='Input')= num(workspaceStat.tokens && workspaceStat.tokens.input)
                      td(data-label='Cached')= num(workspaceStat.tokens && workspaceStat.tokens.cached)
                      td(data-label='Output')= num(workspaceStat.tokens && workspaceStat.tokens.output)
                      td(data-label='Reasoning')= num(workspaceStat.tokens && workspaceStat.tokens.reasoning)
                      td(data-label='Avg Time')= duration(workspaceStat.avgDurationMs)
                      td(data-label='Success')= pct(workspaceStat.successRate)
                      td(data-label='Cost')= money(workspaceStat.cost)
                else
                  tr
                    td(colspan='10') No workspace activity recorded for the last 3 months.

        section.codex-panel.codex-panel--full
          .codex-panel__header
            h2 Recent Sessions
            span.codex-chip(data-codex-session-count)= recentSessions.length
          .codex-table-wrap
            table.codex-table(data-codex-session-table)
              thead
                tr
                  th Title
                  th Workspace
                  th Status
                  th Updated
              tbody
                if recentSessions.length
                  each session in recentSessions
                    tr
                      td(data-label='Title')
                        a(href=`/codex/sessions/${session.id}`)= session.title
                        if session.lastResponsePreview
                          small= session.lastResponsePreview
                      td(data-label='Workspace')= session.workspace ? session.workspace.name : '-'
                      td(data-label='Status')
                        span(class=statusClass(session.status))= session.status
                      td(data-label='Updated')= fmt(session.updatedAt)
                else
                  tr
                    td(colspan='4') No Codex sessions yet.

block script
  script#codex-page-data(type='application/json')!= codexStateJson
  script(src='/js/codex.js', defer)
