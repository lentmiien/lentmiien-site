extends layout

block styles
  link(rel='stylesheet', href='/css/minute_logger_admin.css')

block content
  -
    const hasPackageLegend = Array.isArray(packageLegend) && packageLegend.length;
    const showNoActiveLegend = noActivePackageLegend && Number(noActivePackageLegend.count) > 0;
    const hasBatteryPackageStats = Array.isArray(batteryPackageStats) && batteryPackageStats.length;
    const hasCharging = chargingSummary && chargingSummary.hasCharging;
    const hasChargingPackageStats = Array.isArray(chargingPackageStats) && chargingPackageStats.length;

  .minute-logger-admin
    header.minute-logger-hero.minute-logger-hero--compact
      .minute-logger-hero__content
        p.minute-logger-eyebrow Battery Stats Tracker
        h1.minute-logger-title Battery Tracker
        p.minute-logger-subtitle Charge level, battery temperature, and foreground package context across retained minute logs.
        dl.minute-logger-hero__meta
          div
            dt Endpoint
            dd
              code= endpointPath
          div
            dt Retention
            dd Last #{rawRetentionDays} days
          div
            dt Window
            dd #{windowHours} hours
      .minute-logger-hero__actions
        span Last updated #{generatedAtDisplay}
        .minute-logger-action-stack
          a.minute-logger-refresh(href='/admin/minute-logger') Dashboard
          a.minute-logger-refresh(href='/admin/minute-logger/locations') Locations
          a.minute-logger-refresh(href='/admin/minute-logger/battery') Refresh

    if loadError
      .minute-logger-alert.minute-logger-alert--error= loadError
    else
      section.minute-logger-cards
        each card in overviewCards
          article.minute-logger-card(class=card.tone ? `minute-logger-card--${card.tone}` : '')
            p.minute-logger-card__label= card.label
            strong.minute-logger-card__value= card.value
            if card.helper
              p.minute-logger-card__helper= card.helper

      section.minute-logger-panel.minute-logger-panel--wide
        header.minute-logger-panel__header
          div
            h2 Battery Timeline
            span #{pointCountDisplay} retained points, #{packageCountDisplay} packages
        .minute-logger-battery-chart(data-minute-logger-battery)
          .minute-logger-battery-chart__stage
            svg.minute-logger-battery-chart__svg(viewBox='0 0 960 430', role='img', aria-label='Battery charge and temperature over time', data-minute-logger-battery-svg)
          .minute-logger-battery-chart__controls
            output#minuteLoggerBatteryWindowStart.minute-logger-battery-chart__time(for='minuteLoggerBatterySlider', data-minute-logger-battery-start)= retentionStartDisplay
            input#minuteLoggerBatterySlider.minute-logger-battery-chart__slider(type='range', min='0', max='0', step='60', value='0', aria-label='Battery tracker window start', data-minute-logger-battery-slider)
            output#minuteLoggerBatteryWindowEnd.minute-logger-battery-chart__time(for='minuteLoggerBatterySlider', data-minute-logger-battery-end)= retentionEndDisplay
          .minute-logger-battery-chart__summary(data-minute-logger-battery-summary) #{pointCountDisplay} retained points

      section.minute-logger-panel.minute-logger-panel--wide
        header.minute-logger-panel__header
          div
            h2 Package Battery Stats
            span Observed readings plus inferred unused minutes
        if hasBatteryPackageStats
          .minute-logger-table-wrap
            table.minute-logger-table.minute-logger-table--battery
              thead
                tr
                  th Package
                  th Minutes
                  th Pings
                  th Inferred
                  th Avg Temp
                  th Max Temp
                  th Avg Charge
                  th Drop
                  th Drain
                  th Devices
              tbody
                each pkg in batteryPackageStats
                  tr
                    td
                      .minute-logger-battery-package-cell(style=`--package-color: ${pkg.color};`)
                        span.minute-logger-package-legend__swatch
                        code= pkg.name
                    td= pkg.totalMinutesDisplay
                    td= pkg.observedPointsDisplay
                    td= pkg.inferredMinutesDisplay
                    td= pkg.averageTempDisplay
                    td= pkg.maxTempDisplay
                    td= pkg.averageChargeDisplay
                    td= pkg.chargeDropDisplay
                    td= pkg.drainRateDisplay
                    td= pkg.deviceCountDisplay
        else
          p.minute-logger-empty No package battery analytics in retained minute logs.

      section.minute-logger-grid
        article.minute-logger-panel
          header.minute-logger-panel__header
            div
              h2 Package Colors
              span Background bands
          if hasPackageLegend || showNoActiveLegend
            .minute-logger-package-legend
              if showNoActiveLegend
                .minute-logger-package-legend__item(style=`--package-color: ${noActivePackageLegend.color};`)
                  span.minute-logger-package-legend__swatch
                  code= noActivePackageLegend.name
                  span #{noActivePackageLegend.countDisplay} pings
              each pkg in packageLegend
                .minute-logger-package-legend__item(style=`--package-color: ${pkg.color};`)
                  span.minute-logger-package-legend__swatch
                  code= pkg.name
                  span #{pkg.countDisplay} pings
          else
            p.minute-logger-empty No active packages in retained minute logs.

        article.minute-logger-panel
          header.minute-logger-panel__header
            div
              h2 Data Window
              span Raw retention range
          dl.minute-logger-details
            div
              dt Earliest
              dd= retentionStartDisplay
            div
              dt Latest
              dd= retentionEndDisplay
            div
              dt No Package Context
              dd #{noActivePointCountDisplay} pings
            div
              dt Inferred Unused
              dd= inferredUnusedMinutesDisplay
            div
              dt Chart Lines
              dd Charge left and battery temperature

        article.minute-logger-panel
          header.minute-logger-panel__header
            div
              h2 Charging Stats
              span Battery increases
          if hasCharging
            dl.minute-logger-details
              div
                dt Intervals
                dd= chargingSummary.intervalCountDisplay
              div
                dt Charge Gained
                dd= chargingSummary.totalGainDisplay
              div
                dt Charging Time
                dd= chargingSummary.totalDurationDisplay
              div
                dt Avg Speed
                dd= chargingSummary.averageSpeedDisplay
              div
                dt Max Speed
                dd= chargingSummary.maxSpeedDisplay
              div
                dt Avg Temp
                dd= chargingSummary.averageTempDisplay
              div
                dt Max Temp
                dd= chargingSummary.maxTempDisplay
              div
                dt Devices
                dd= chargingSummary.deviceCountDisplay
          else
            p.minute-logger-empty No charging intervals detected in retained battery readings.

        article.minute-logger-panel
          header.minute-logger-panel__header
            div
              h2 Charging Packages
              span Foreground during increases
          if hasChargingPackageStats
            .minute-logger-battery-stat-list
              each pkg in chargingPackageStats
                .minute-logger-battery-stat(style=`--package-color: ${pkg.color};`)
                  .minute-logger-battery-stat__top
                    span.minute-logger-package-legend__swatch
                    code= pkg.name
                    strong= pkg.totalGainDisplay
                  .minute-logger-battery-stat__meta
                    span #{pkg.averageSpeedDisplay} avg
                    span #{pkg.maxSpeedDisplay} max
                    span #{pkg.averageTempDisplay} temp
                    span #{pkg.intervalCountDisplay} intervals
          else
            p.minute-logger-empty No package context for charging intervals.

block script
  script(type='application/json', id='minuteLoggerBatteryData')!= batteryTrackerJson
  script(src='/js/minute_logger_battery.js', defer)
