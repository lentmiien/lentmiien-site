extends layout

block styles
  link(rel='stylesheet', href='https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;800&display=swap')
  link(rel='stylesheet', href='/css/public_tobuy_list.css')

block content
  .public-tobuy-page
    .public-tobuy-shell
      header.public-tobuy-hero
        p.public-tobuy-eyebrow 公開ツール
        .public-tobuy-title-row
          h1= pageHeading
          span.public-tobuy-count= `未完了 ${taskCount}件`
        p.public-tobuy-subtitle 買うものリストと、公開している小さな統計をまとめています。

      if successMessage
        .public-tobuy-alert.public-tobuy-alert--success= successMessage

      if errorMessage
        .public-tobuy-alert.public-tobuy-alert--error= errorMessage

      if lastKnownLocation
        section.public-tobuy-panel.public-tobuy-location-panel(aria-label='最後にわかった場所')
          p.public-tobuy-location-panel__label 最後にわかった場所
          p.public-tobuy-location-panel__value= lastKnownLocation.display

      section.public-tobuy-panel.public-tobuy-counter-panel
        .public-tobuy-section-head.public-tobuy-section-head--split
          h2 端末利用
          if deviceUsageStats && deviceUsageStats.generatedAtDisplay
            span.public-tobuy-section-meta= `最終更新 ${deviceUsageStats.generatedAtDisplay}`
        if deviceUsageStats && deviceUsageStats.loadError
          p.public-tobuy-empty= deviceUsageStats.loadError
        else if deviceUsageStats && (deviceUsageStats.rollingUsageCard || deviceUsageStats.learningGateCard)
          .public-tobuy-usage-cards
            if deviceUsageStats.rollingUsageCard
              - const rollingCard = deviceUsageStats.rollingUsageCard;
              article.public-tobuy-counter-card(class=rollingCard.tone ? `public-tobuy-counter-card--${rollingCard.tone}` : '')
                p.public-tobuy-counter-card__label= rollingCard.label
                p.public-tobuy-counter-card__value.public-tobuy-counter-card__value--primary= rollingCard.value
                if rollingCard.helper
                  p.public-tobuy-counter-card__helper= rollingCard.helper
            if deviceUsageStats.learningGateCard
              - const learningCard = deviceUsageStats.learningGateCard;
              article.public-tobuy-counter-card(class=learningCard.tone ? `public-tobuy-counter-card--${learningCard.tone}` : '')
                p.public-tobuy-counter-card__label= learningCard.label
                p.public-tobuy-counter-card__value.public-tobuy-counter-card__value--primary= learningCard.value
                if learningCard.helper
                  p.public-tobuy-counter-card__helper= learningCard.helper
        else
          p.public-tobuy-empty 端末利用の記録はまだありません。

      section.public-tobuy-panel.public-tobuy-rewards-panel
        .public-tobuy-section-head.public-tobuy-section-head--split
          h2 ご褒美
          if deviceUsageStats && deviceUsageStats.rewardSummary
            span.public-tobuy-section-meta= `今日 ${deviceUsageStats.rewardSummary.pointsDisplay}`
        if deviceUsageStats && deviceUsageStats.loadError
          p.public-tobuy-empty= deviceUsageStats.loadError
        else
          if deviceUsageStats && deviceUsageStats.rewardSummary
            .public-tobuy-reward-summary
              strong.public-tobuy-reward-summary__points= deviceUsageStats.rewardSummary.pointsDisplay
              span.public-tobuy-reward-summary__meta= `今日の合計・${deviceUsageStats.rewardSummary.countDisplay}`
          form.public-tobuy-form.public-tobuy-reward-form(method='post', action=rewardSubmitPath)
            if deviceUsageStats && deviceUsageStats.rewardSuggestions && deviceUsageStats.rewardSuggestions.length
              label.public-tobuy-label(for='publicRewardSuggestion') 候補
              select#publicRewardSuggestion.public-tobuy-select(name='suggestionId')
                option(value='') 自由入力
                each suggestion in deviceUsageStats.rewardSuggestions
                  option(
                    value=suggestion.id,
                    data-title-en=suggestion.titleEn,
                    data-points=suggestion.defaultPoints,
                    selected=rewardForm && rewardForm.suggestionId === suggestion.id
                  ) #{suggestion.displayTitle}（#{suggestion.pointsDisplay}）
            .public-tobuy-form-grid
              label.public-tobuy-field(for='rewardTitleEn')
                span ご褒美の内容
                input#rewardTitleEn.public-tobuy-input(
                  type='text'
                  name='titleEn'
                  value=rewardForm ? rewardForm.titleEn : ''
                  maxlength='160'
                  placeholder='読書をがんばった'
                  autocomplete='off'
                )
              label.public-tobuy-field.public-tobuy-field--points(for='rewardPoints')
                span ポイント
                input#rewardPoints.public-tobuy-input(
                  type='number'
                  name='points'
                  value=rewardForm ? rewardForm.points : '1'
                  min='0'
                  max='100000'
                  step='1'
                  inputmode='numeric'
                )
            label.public-tobuy-field(for='rewardComment')
              span メモ
              textarea#rewardComment.public-tobuy-textarea(
                name='comment'
                rows='3'
                maxlength='1000'
                placeholder='がんばったことなど'
              )= rewardForm ? rewardForm.comment : ''
            button.public-tobuy-button(type='submit') ご褒美を追加

      section.public-tobuy-panel.public-tobuy-cooking-panel
        .public-tobuy-section-head.public-tobuy-section-head--split
          h2 今日の料理
          if todayCooking && todayCooking.date
            span.public-tobuy-section-meta= todayCooking.weekdayDisplay ? `${todayCooking.date}・${todayCooking.weekdayDisplay}` : todayCooking.date
        if todayCooking && todayCooking.loadError
          p.public-tobuy-empty= todayCooking.loadError
        else if todayCooking && todayCooking.entries && todayCooking.entries.length
          ul.public-tobuy-cooking-list
            each entry in todayCooking.entries
              li.public-tobuy-cooking-item
                span.public-tobuy-cooking-item__category= entry.category
                .public-tobuy-cooking-item__main
                  if entry.imageSrc
                    img.public-tobuy-cooking-item__preview(src=entry.imageSrc, alt=`${entry.title}の画像`, loading='lazy')
                  span.public-tobuy-cooking-item__title= entry.title
        else
          p.public-tobuy-empty 未設定です。

      section.public-tobuy-panel
        form.public-tobuy-form(method='post', action=submitPath)
          label.public-tobuy-label(for='title') 買うものを追加
          .public-tobuy-form-row
            input#title.public-tobuy-input(
              type='text'
              name='title'
              value=formTitle
              maxlength='200'
              placeholder='牛乳、玉ねぎ、食器用洗剤'
              autocomplete='off'
              required
            )
            button.public-tobuy-button(type='submit') 追加
          p.public-tobuy-hint 追加制限: 1秒に1回、1日10件まで。

      section.public-tobuy-panel
        .public-tobuy-section-head
          h2 買うものリスト
        if tasks.length
          ul.public-tobuy-list
            each task, index in tasks
              li.public-tobuy-item(style=`--item-index:${index};`)
                span.public-tobuy-item__marker
                span.public-tobuy-item__title= task.title
        else
          p.public-tobuy-empty 今は何もありません。

      section.public-tobuy-panel.public-tobuy-daily-panel
        .public-tobuy-section-head.public-tobuy-section-head--split
          h2 日別の分数
          span.public-tobuy-section-meta カテゴリー別
        if deviceUsageStats && deviceUsageStats.loadError
          p.public-tobuy-empty= deviceUsageStats.loadError
        else if deviceUsageStats && deviceUsageStats.dailyStats && deviceUsageStats.dailyStats.length
          .public-tobuy-days
            each day in deviceUsageStats.dailyStats
              .public-tobuy-day
                .public-tobuy-day__top
                  span.public-tobuy-day__date= day.isToday ? `${day.dateKey}（今日）` : day.dateKey
                  strong= day.totalDurationDisplay
                .public-tobuy-day__bar(style=`--total-percent: ${day.totalPercent}%;`)
                  span.public-tobuy-day__bar-total
                    each category in day.categories
                      span.public-tobuy-day__bar-category(
                        style=`--category-width: ${category.percent}%; --category-color: ${category.color};`
                        title=`${category.label}: ${category.durationDisplay}`
                      )
                if day.categories && day.categories.length
                  ul.public-tobuy-day__categories
                    each category in day.categories
                      li.public-tobuy-day__category(style=`--category-color: ${category.color};`)
                        span.public-tobuy-day__category-swatch
                        span.public-tobuy-day__category-name= category.label
                        span.public-tobuy-day__category-duration= category.durationDisplay
        else
          p.public-tobuy-empty 端末利用の分数はまだありません。

block script
  script(src='/js/public_tobuy_list.js', defer)
