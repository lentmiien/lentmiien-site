extends ../layout

block styles
  link(rel='stylesheet', href='/css/trellis2.css')

block content
  main.trellis2-page.pixal3d-page
    header.trellis2-hero
      .trellis2-hero__copy
        p.trellis2-eyebrow Pixal3D
        h1 Build a textured 3D model from one image
        p Upload a clean object reference, tune camera and sampling controls, and Pixal3D will produce a downloadable GLB.
      .trellis2-service
        span#pixal3dServiceBadge.trellis2-badge.trellis2-badge--pending Checking service
        button#pixal3dServiceRefresh.btn.btn-outline-light.btn-sm(type='button') Refresh

    #pixal3dAlert.trellis2-alert(
      role='status',
      aria-live='polite',
      class=queuedNotice ? 'trellis2-alert--success' : '',
      hidden=!queuedNotice
    )= queuedNotice ? 'Your Pixal3D job was queued. This page will update when it finishes.' : ''

    section.trellis2-panel(aria-labelledby='pixal3dGenerateHeading')
      .trellis2-panel__heading
        div
          p.trellis2-eyebrow New model
          h2#pixal3dGenerateHeading Generation settings
        p The job runs in the background. The 1536 preset is considerably heavier than 1024.

      form#pixal3dGenerateForm.trellis2-form(action='/pixal3d/jobs', method='post', enctype='multipart/form-data')
        .trellis2-upload
          .trellis2-upload__field
            label.form-label(for='pixal3dImage') Reference image
            input#pixal3dImage.form-control(
              type='file',
              name='image',
              accept='image/png,image/jpeg,image/webp',
              required
            )
            p.form-text PNG, JPEG, or WebP, up to #{maxImageMiB} MiB and 25 megapixels. Use one complete, centered object with a clean background and a little margin.
          figure#pixal3dPreview.trellis2-preview(hidden)
            img#pixal3dPreviewImage(alt='Selected image preview')
            figcaption Input preview

        .trellis2-parameter-grid
          .trellis2-field
            label.form-label(for='pixal3dSeed') Seed
            input#pixal3dSeed.form-control(type='number', name='seed', min='0', max='2147483647', step='1', value=defaults.seed, required)
            p.form-text Compare seeds to vary inferred hidden geometry.
          .trellis2-field
            label.form-label(for='pixal3dResolution') Generation resolution
            select#pixal3dResolution.form-select(name='resolution', required)
              each option in [1024, 1536]
                option(value=option, selected=defaults.resolution === option)= `${option}`
            p.form-text Start at 1024; use 1536 only for a quality experiment.
          .trellis2-field
            label.form-label(for='pixal3dTextureSize') Texture size
            select#pixal3dTextureSize.form-select(name='texture_size', required)
              each option in [1024, 2048, 4096]
                option(value=option, selected=defaults.textureSize === option)= `${option} px`
            p.form-text Size of the exported texture maps.
          .trellis2-field
            label.form-label(for='pixal3dDecimation') Target triangle count
            input#pixal3dDecimation.form-control(
              type='number',
              name='decimation_target',
              min='10000',
              max='1000000',
              step='1',
              value=defaults.decimationTarget,
              required
            )
            p.form-text Approximate target from 10,000 to 1,000,000 triangles.

        details.trellis2-advanced
          summary Camera and mesh extraction controls
          .trellis2-parameter-grid.trellis2-parameter-grid--advanced
            .trellis2-field
              label.form-label(for='pixal3dFov') Horizontal camera FOV
              input#pixal3dFov.form-control(type='number', name='fov_degrees', min='0', max='120', step='0.01', value=defaults.fovDegrees, required)
              p.form-text Use 0 for automatic estimation, or 5–120 degrees for a known camera.
            .trellis2-field
              label.form-label(for='pixal3dMeshScale') Mesh scale
              input#pixal3dMeshScale.form-control(type='number', name='mesh_scale', min='0.25', max='4', step='0.01', value=defaults.meshScale, required)
              p.form-text Projection and camera scale used for conditioning.
            .trellis2-field
              label.form-label(for='pixal3dExtendPixel') Framing adjustment
              input#pixal3dExtendPixel.form-control(type='number', name='extend_pixel', min='-128', max='128', step='1', value=defaults.extendPixel, required)
              p.form-text Pixel adjustment used when deriving camera distance.
            .trellis2-field
              label.form-label(for='pixal3dMaxTokens') Maximum sparse tokens
              input#pixal3dMaxTokens.form-control(type='number', name='max_num_tokens', min='8192', max='100000', step='1', value=defaults.maxNumTokens, required)
              p.form-text Higher values may retain complexity but use more memory.
            .trellis2-field
              label.form-label(for='pixal3dDcResolution') Extraction resolution
              select#pixal3dDcResolution.form-select(name='dc_resolution', required)
                each option in [128, 192, 256]
                  option(value=option, selected=defaults.dcResolution === option)= `${option}`
              p.form-text Dual-contouring resolution used to extract the mesh.
            .trellis2-field
              label.form-label(for='pixal3dSmoothIterations') Smoothing iterations
              input#pixal3dSmoothIterations.form-control(type='number', name='smooth_iterations', min='0', max='20', step='1', value=defaults.smoothIterations, required)
              p.form-text Optional smoothing before export; 0 preserves the raw shape.

        details.trellis2-advanced
          summary Advanced sampling controls
          .trellis2-parameter-grid.trellis2-parameter-grid--advanced
            .trellis2-field
              label.form-label(for='pixal3dSparseSteps') Sparse structure steps
              input#pixal3dSparseSteps.form-control(type='number', name='sparse_structure_steps', min='1', max='50', step='1', value=defaults.sparseStructureSteps, required)
            .trellis2-field
              label.form-label(for='pixal3dSparseGuidance') Sparse structure guidance
              input#pixal3dSparseGuidance.form-control(type='number', name='sparse_structure_guidance', min='0', max='30', step='0.1', value=defaults.sparseStructureGuidance, required)
            .trellis2-field
              label.form-label(for='pixal3dSparseRescale') Sparse guidance rescale
              input#pixal3dSparseRescale.form-control(type='number', name='sparse_structure_guidance_rescale', min='0', max='1', step='0.01', value=defaults.sparseStructureGuidanceRescale, required)
            .trellis2-field
              label.form-label(for='pixal3dShapeSteps') Shape steps
              input#pixal3dShapeSteps.form-control(type='number', name='shape_steps', min='1', max='50', step='1', value=defaults.shapeSteps, required)
            .trellis2-field
              label.form-label(for='pixal3dShapeGuidance') Shape guidance
              input#pixal3dShapeGuidance.form-control(type='number', name='shape_guidance', min='0', max='30', step='0.1', value=defaults.shapeGuidance, required)
            .trellis2-field
              label.form-label(for='pixal3dShapeRescale') Shape guidance rescale
              input#pixal3dShapeRescale.form-control(type='number', name='shape_guidance_rescale', min='0', max='1', step='0.01', value=defaults.shapeGuidanceRescale, required)
            .trellis2-field
              label.form-label(for='pixal3dTextureSteps') Texture steps
              input#pixal3dTextureSteps.form-control(type='number', name='texture_steps', min='1', max='50', step='1', value=defaults.textureSteps, required)
            .trellis2-field
              label.form-label(for='pixal3dTextureGuidance') Texture guidance
              input#pixal3dTextureGuidance.form-control(type='number', name='texture_guidance', min='0', max='30', step='0.1', value=defaults.textureGuidance, required)
            .trellis2-field
              label.form-label(for='pixal3dTextureRescale') Texture guidance rescale
              input#pixal3dTextureRescale.form-control(type='number', name='texture_guidance_rescale', min='0', max='1', step='0.01', value=defaults.textureGuidanceRescale, required)

        .trellis2-switches
          .form-check.form-switch
            input(type='hidden', name='preprocess_image', value='false')
            input#pixal3dPreprocess.form-check-input(type='checkbox', name='preprocess_image', value='true', checked=defaults.preprocessImage)
            label.form-check-label(for='pixal3dPreprocess') Remove the background and crop the subject
          .form-check.form-switch
            input(type='hidden', name='fill_holes', value='false')
            input#pixal3dFillHoles.form-check-input(type='checkbox', name='fill_holes', value='true', checked=defaults.fillHoles)
            label.form-check-label(for='pixal3dFillHoles') Fill holes during mesh extraction

        .trellis2-form__actions
          button#pixal3dSubmit.btn.btn-primary(type='submit') Generate 3D model
          span#pixal3dSubmitStatus.trellis2-muted(aria-live='polite')

    section.trellis2-history(aria-labelledby='pixal3dHistoryHeading')
      .trellis2-history__heading
        div
          p.trellis2-eyebrow Library
          h2#pixal3dHistoryHeading Recent Pixal3D jobs
        p #{pagination.totalJobs} visible #{pagination.totalJobs === 1 ? 'job' : 'jobs'} · your jobs and models shared by other users

      if jobs.length
        .trellis2-jobs
          each job in jobs
            article.trellis2-job(data-pixal3d-job-id=job.id, data-pixal3d-job-status=job.status)
              .trellis2-job__media
                img(src=job.inputImage.publicUrl, alt=`Reference image for ${job.inputImage.originalName || 'Pixal3D job'}`, loading='lazy')
                span.trellis2-status(class=`trellis2-status--${job.status}`, data-pixal3d-status)= job.statusLabel
              .trellis2-job__body
                .trellis2-job__heading
                  div
                    h3= job.inputImage.originalName || 'Pixal3D job'
                    p.trellis2-byline
                      span= job.ownerLabel
                      span(aria-hidden='true') ·
                      time(datetime=job.createdAtIso)= job.createdAtLabel
                  if !job.isOwner && job.shared
                    span.trellis2-shared-label Shared

                if job.error
                  p.trellis2-job__error= job.error

                dl.trellis2-metadata
                  div
                    dt Input
                    dd #{job.inputImage.width} × #{job.inputImage.height} · #{job.inputSizeLabel}
                  div
                    dt Generation
                    - const actualResolution = job.metrics.actualResolution != null ? job.metrics.actualResolution : job.parameters.resolution
                    dd #{actualResolution} resolution · seed #{job.parameters.seed}
                  div
                    dt Export
                    dd #{Number(job.parameters.decimationTarget).toLocaleString('en-US')} target triangles · #{job.parameters.textureSize}px texture
                  div
                    dt Camera
                    dd= job.cameraLabel
                  div
                    dt Extraction
                    dd #{job.parameters.dcResolution} dual contouring · #{job.parameters.smoothIterations} smoothing #{job.parameters.smoothIterations === 1 ? 'pass' : 'passes'}
                  div
                    dt Preparation
                    dd= `${job.parameters.preprocessImage ? 'Preprocessed' : 'Original framing'} · ${job.parameters.fillHoles ? 'Holes filled' : 'No hole filling'}`
                  if job.durationLabel
                    div
                      dt Runtime
                      dd= job.durationLabel
                  if job.metrics.sourceFaces != null && job.metrics.sourceVertices != null
                    div
                      dt Source mesh
                      dd #{Number(job.metrics.sourceFaces).toLocaleString('en-US')} faces · #{Number(job.metrics.sourceVertices).toLocaleString('en-US')} vertices
                  if job.outputSizeLabel
                    div
                      dt GLB file
                      dd= job.outputSizeLabel
                  if job.metrics.peakAllocatedMiB != null || job.metrics.peakReservedMiB != null
                    div
                      dt Peak VRAM
                      if job.metrics.peakAllocatedMiB != null && job.metrics.peakReservedMiB != null
                        dd #{Number(job.metrics.peakAllocatedMiB).toLocaleString('en-US')} MiB allocated · #{Number(job.metrics.peakReservedMiB).toLocaleString('en-US')} MiB reserved
                      else
                        dd #{Number(job.metrics.peakAllocatedMiB != null ? job.metrics.peakAllocatedMiB : job.metrics.peakReservedMiB).toLocaleString('en-US')} MiB
                  if job.gatewayJobId
                    div.trellis2-metadata__wide
                      dt Gateway job
                      dd
                        code= job.gatewayJobId

                .trellis2-job__actions
                  if job.downloadUrl
                    a.btn.btn-primary(href=job.downloadUrl) Download GLB
                  else if job.status === 'queued' || job.status === 'processing'
                    span.trellis2-muted(data-pixal3d-progress) The model will appear here when generation finishes.

                  if job.isOwner
                    .trellis2-owner-actions
                      .trellis2-share
                        .form-check.form-switch
                          input.form-check-input(
                            id=`pixal3dShare-${job.id}`,
                            type='checkbox',
                            checked=job.shared,
                            data-pixal3d-share
                          )
                          label.form-check-label(for=`pixal3dShare-${job.id}`) Share with other users
                        span.trellis2-share__status(data-pixal3d-share-status, aria-live='polite')
                      button.btn.btn-outline-danger.btn-sm(
                        type='button',
                        data-pixal3d-delete,
                        disabled=job.status === 'queued' || job.status === 'processing',
                        title=job.status === 'queued' || job.status === 'processing' ? 'This job can be deleted after generation finishes.' : 'Delete this job and its stored files.'
                      ) Delete job
      else
        .trellis2-empty
          h3 No Pixal3D models yet
          p Upload an image above to create the first model in your library.

      if pagination.totalPages > 1
        nav.trellis2-pagination(aria-label='Pixal3D job pages')
          if pagination.previousUrl
            a.trellis2-page-link(href=pagination.previousUrl, rel='prev') Previous
          else
            span.trellis2-page-link.trellis2-page-link--disabled Previous
          each link in pagination.links
            if link.ellipsis
              span.trellis2-page-ellipsis …
            else if link.current
              span.trellis2-page-link.trellis2-page-link--current(aria-current='page')= link.page
            else
              a.trellis2-page-link(href=link.href)= link.page
          if pagination.nextUrl
            a.trellis2-page-link(href=pagination.nextUrl, rel='next') Next
          else
            span.trellis2-page-link.trellis2-page-link--disabled Next

block script
  script(src='/js/pixal3d.js', defer)
