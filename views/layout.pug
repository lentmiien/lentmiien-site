mixin navColumn(title)
  .navbar-column
    if title
      h2= title
    block

mixin navLink(href, label, variant)
  - const linkClass = variant === 'secondary' ? 'type-2-link' : 'type-1-link';
  a(class=linkClass, href=href)&attributes(attributes)= label

doctype html
html(lang=pageLang || 'en')
  head
    if gtag
      script(async src="https://www.googletagmanager.com/gtag/js?id=G-RGSSE514L4")
      script.
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-RGSSE514L4', { cookie_domain: 'home.lentmiien.com', cookie_flags: 'SameSite=None;Secure' });
    title= pageTitle || "Lennart's Website"
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    //- Social media meta tags - start
    meta(property='og:title', content=og_title)
    meta(property='og:type', content=og_type)
    meta(property='og:url', content=og_url)
    meta(property='og:image', content=og_image)
    meta(property='og:description', content=og_description)
    meta(property='og:site_name', content=og_site_name)
    meta(property='og:image:width', content=og_image_width)
    meta(property='og:image:height', content=og_image_height)
    meta(name='twitter:card', content=twitter_card)
    meta(name='twitter:creator', content=twitter_creator)
    meta(name='twitter:title', content=twitter_title)
    meta(name='twitter:description', content=twitter_description)
    meta(name='twitter:image', content=twitter_image)
    meta(name='twitter:image:alt', content=twitter_image_alt)
    //- Social media meta tags - end
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous")
    link(rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css")
    link(rel="stylesheet" href="https://uicdn.toast.com/editor/latest/theme/toastui-editor-dark.min.css")
    link(rel="stylesheet", href="/css/color-theme.css")
    link(rel="stylesheet", href="/css/style.css")
    link(rel="stylesheet", href="/css/nav.css")
    link(rel="stylesheet", href="/css/brand.css")
    block styles
  body
    .nav-placeholder
    .navbar-icon(onclick="toggleNavbar()") ☰
    a#goTopPageBtn.nav-action-btn(href=`${loggedIn ? "/mypage" : "/"}`) ⌂
    button#actionBtn.nav-action-btn(disabled) ---
    #navbar.navbar
      - const hasPermission = (permission) => Array.isArray(permissions) && permissions.indexOf(permission) >= 0;
      if loggedIn === true && hasPermission("quicknote")
        +navColumn('Quick Add')
          form#quickNoteForm
            .input-group.mb-1
              input#quickNoteInput.form-control(type='text' placeholder='Quick note...')
              .input-group-append
                button.btn.btn-primary(type='submit') Save
          form#locationForm
            .input-group.mb-1
              input#locationInput.form-control(type='text' placeholder='Location name...')
              .input-group-append
                button.btn.btn-primary(type='submit') Add location
      +navColumn('Content')
        +navLink('/blog', 'Blog')
        +navLink('/blog/Personal/list', 'Personal', 'secondary')
        +navLink('/blog/Programming/list', 'Programming', 'secondary')
        +navLink('/blog/Food/list', 'Food', 'secondary')
        if loggedIn == true
          +navLink('/learning', 'Learning Lab')
          +navLink('/mypage/blogpost', 'Write blog', 'secondary')
        +navLink('/cookingp', 'Cooking public page')
        +navLink('/games', 'Games')
      +navColumn('Tools')
        +navLink('/yaml-viewer', 'YAML viewer')
        +navLink('/exchange-rates', 'Exchange rates')
      if loggedIn == true
        - const canUseTestLinks = hasPermission("test");
        - const showUtilityLinks = canUseTestLinks || hasPermission("box") || hasPermission("binpacking") || hasPermission("quicknote") || hasPermission("product") || hasPermission("gallery");
        - const showLifeAdmin = hasPermission("accounting") || hasPermission("budget") || hasPermission("receipt") || hasPermission("payroll") || hasPermission("scheduletask") || hasPermission("emergencystock") || hasPermission("shoppinglist") || canUseTestLinks;
        if chatmode
          +navColumn('Chat History')
            +navLink('/chat3', 'New chat')
            li.nav-item.dropdown
              a.nav-link.dropdown-toggle(href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false") History
              ul.dropdown-menu
                li#history_list
                  button.dropdown-item(onclick="showHModalPopup()") Show all
                  hr
            li.nav-item.dropdown
              a.nav-link.dropdown-toggle(href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false") Select head
              ul.dropdown-menu
                li#head_list
        if hasPermission("chat5")
          +navColumn('Chat & Knowledge')
            +navLink('/chat5/top', 'ChatGPT')
            +navLink('/chat5/drafting-presets', 'Drafting presets', 'secondary')
            if hasPermission("chat4")
              +navLink('/chat4/knowledgelist', 'Knowledge', 'secondary')
              +navLink('/chat4/templates', 'Templates', 'secondary')
            +navLink('/chat5', 'Chat5 classic', 'secondary')
            +navLink('/chat5/ai_model_cards', 'AI model cards', 'secondary')
        +navColumn('AI & Media')
          +navLink('/gpt-image', 'GPT Image 2')
          if hasPermission("image_gen")
            +navLink('/image_gen', 'ComfyUI')
            +navLink('/image_gen/bulk', 'ComfyUI bulk', 'secondary')
          if hasPermission("ocr")
            +navLink('/ocr', 'OCR tool')
            +navLink('/ocr-tts', 'OCR to TTS', 'secondary')
          if hasPermission("sora")
            +navLink('/sora', 'Sora')
          if canUseTestLinks
            +navLink('/ai-cluster-planner', 'AI cluster planner', 'secondary')
          if hasPermission("asr")
            +navLink('/asr', 'Audio transcription')
          if hasPermission("music")
            +navLink('/music', 'Music library')
          +navLink('/qwen3-lora', 'Qwen3 LoRA')
          +navLink('/trellis2', 'Image to 3D')
          +navLink('/lego-sculpture-converter', 'Lego sculpture converter', 'secondary')
          +navLink('/codex', 'Codex')
        if showUtilityLinks
          +navColumn('Utilities')
            if hasPermission("box")
              +navLink('/box', 'Box packer')
            if hasPermission("binpacking")
              +navLink('/binpacking', '3D Bin Packing')
            if canUseTestLinks
              +navLink('/mypage/pdf_to_jpg', 'PDF to JPG')
            if hasPermission("quicknote")
              +navLink('/quicknote', 'Quick note')
            if hasPermission("product")
              +navLink('/product', 'Product details')
            if canUseTestLinks
              +navLink('/diff', 'JSON diff')
            if hasPermission("gallery")
              +navLink('/gallery', 'Gallery')
            if canUseTestLinks
              +navLink('/mypage/github', 'GitHub (lentmiien)', 'secondary')
        if showLifeAdmin
          +navColumn('Life Admin')
            if hasPermission("accounting")
              +navLink('/accounting', 'Accounting hub')
              +navLink('/accounting/external-assets', 'External assets', 'secondary')
              +navLink('/accounting/legacy', 'Legacy budget view', 'secondary')
            if hasPermission("budget")
              +navLink('/budget', 'Accounting (new)')
              +navLink('/budget/review', 'Budget review', 'secondary')
              +navLink('/budget/cards', 'Credit cards', 'secondary')
            if hasPermission("receipt")
              +navLink('/receipt', 'Upload receipt')
            if hasPermission("payroll")
              +navLink('/payroll', 'Payroll')
            if hasPermission("scheduletask")
              +navLink('/scheduleTask/calendar', 'Schedule')
            if hasPermission("emergencystock")
              +navLink('/es/es_dashboard', 'Emergency Stock')
            if hasPermission("shoppinglist")
              +navLink('/shopping-list', 'Shopping list')
        if hasPermission("cooking")
          +navColumn('Cooking')
            +navLink('/cooking', 'Cooking calendar')
            +navLink('/cooking/cookbook', 'Cookbook', 'secondary')
            +navLink('/cookingp?uid=nzz8gXilQBZ8nxS78b0UjhpPtnXqUMFW', 'Maiko cooking request page', 'secondary')
            +navLink('/cookingp?uid=JSqngWDQyGoIVohdrG96dxU6XYSDv98G', 'Mizuki cooking request page', 'secondary')
        if admin
          +navColumn('Admin')
            +navLink('/admin', 'Admin page')
            +navLink('/admin/learning', 'Learning CMS')
            +navLink('/admin/html-pages', 'HTML content')
            +navLink('/admin/project-docs', 'Project docs')
            +navLink('/admin/life_log', 'My Life Log')
            +navLink('/admin/app_logs', 'App logs')
            +navLink('/admin/message-inbox', 'Message inbox')
            +navLink('/admin/message-filters', 'Message filters', 'secondary')
            +navLink('/tmp-files', 'Temp files')
          +navColumn('System Admin')
            +navLink('/admin/performance', 'App Performance')
            +navLink('/admin/request-counter', 'Request Counter')
            +navLink('/admin/app-settings', 'App Settings')
            +navLink('/admin/device-usage', 'Device Usage')
            +navLink('/admin/minute-logger', 'Minute Logger')
            +navLink('/admin/database_usage', 'Database Usage')
            +navLink('/admin/database-viewer', 'Database Viewer')
            +navLink('/admin/amiami-items', 'AmiAmi Items')
            +navLink('/admin/disasters', 'Disaster Dashboard')
            +navLink('/admin/disasters/history', 'Disaster History', 'secondary')
            +navLink('/admin/disasters/weather-history', 'Weather History', 'secondary')
            +navLink('/admin/tapo', 'Tapo Energy')
            +navLink('/admin/tools', 'Tool Manager')
            +navLink('/admin/audio-workflow', 'Audio workflow')
            +navLink('/admin/api-debug-logs', 'API Debug Logs')
            +navLink('/admin/dummy-api-requests', 'Dummy API Requests')
          +navColumn('AI Admin')
            +navLink('/admin/openai_usage', 'OpenAI Usage')
            +navLink('/admin/ai-gateway', 'AI Gateway')
            +navLink('/admin/locateanything', 'LocateAnything')
            +navLink('/admin/qwen3-lora', 'Qwen3 LoRA')
            +navLink('/admin/qwen3-lora/training-groups', 'LoRA training groups', 'secondary')
            +navLink('/admin/agent5', 'Agent5')
            +navLink('/admin/embedding-test', 'Embedding Management')
            +navLink('/admin/tts-test', 'TTS Test')
            +navLink('/admin/music-test', 'Music generator')
            +navLink('/admin/asr-test', 'Audio transcription')
            +navLink('/admin/rag-memory', 'RAG recall test')
        +navColumn('Bookmarks')
          +navLink('/bookmarks', 'Manage bookmarks')
          form.navbar-bookmark-form(method='post', action='/bookmarks/add')
            input(type='hidden', name='returnTo', value=currentPath)
            .mb-1
              input.form-control.form-control-sm(type='text', name='url', placeholder='Paste URL', required)
            .mb-1
              input.form-control.form-control-sm(type='text', name='title', placeholder='Title (optional)', maxlength='160')
            .input-group.input-group-sm
              input.form-control(type='number', name='importance', min='1', max='5', step='1', value='3')
              button.btn.btn-primary(type='submit') Save
          if bookmarks && bookmarks.length
            each bookmark in bookmarks
              - const bookmarkLabel = `[${bookmark.importance}] ${bookmark.title}`;
              +navLink(bookmark.url, bookmarkLabel, 'secondary')(target='_blank', rel='noopener noreferrer')
          else
            small.navbar-html-empty No bookmarks yet.
      else
        +navColumn('Account')
          +navLink('/login', 'Log in')
      +navColumn('Samples & Demos')
        if htmlPaths && htmlPaths.length
          each l in htmlPaths
            .navbar-html-entry
              +navLink(l.path, l.name, 'secondary')(target="_blank", rel="noopener noreferrer")
              - const avgDisplay = typeof l.averageRating === 'number' ? l.averageRating.toFixed(2) : null;
              - const ratingParts = Array.isArray(l.ratings) ? l.ratings.filter(r => Number.isFinite(r.score)).map(r => `${r.label}: ${r.score}`) : [];
              if avgDisplay || ratingParts.length
                small.navbar-html-rating
                  if avgDisplay
                    span.navbar-html-rating-avg Avg #{avgDisplay}
                    if l.version
                      span.navbar-html-rating-version  | v#{l.version}
                  if ratingParts.length
                    if avgDisplay
                      span.navbar-html-rating-sep  |
                    span.navbar-html-rating-breakdown= ratingParts.join(' | ')
        else
          small.navbar-html-empty No public demos yet.
    .container-fluid
      block content
    div(style="height:50px;")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous")
    script(src="/js/nav.js", defer) 
    script(src="/js/layout.js", defer) 
    script(src="https://cdn.socket.io/4.0.0/socket.io.min.js", defer)
    script(src="/js/notifications.js", defer) 
    block script
