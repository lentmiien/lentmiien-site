      input#members.form-control(type="text", value=conversation.members.join(", "))
      .chat5-update-actions.d-flex.justify-content-evenly.flex-wrap.gap-2
        button#updateSettingsButton.btn.btn-success(type="button", onclick="UpdateConversation()", disabled=conversationSource !== 'conversation5') Update
    #pills-training.tab-pane.fade.chat5-pane(role="tabpanel" aria-labelledby="pills-training-tab" tabindex="0")
      .chat5-training-toolbar
        div
          h3.mb-1 Add to training
          p.text-muted.mb-0 Select one or more prompt messages and one output message for a training group.
        a.btn.btn-outline-primary.btn-sm(href="/admin/qwen3-lora/training-groups") Manage groups
      if trainingFlash.error
        .alert.alert-danger.mt-3.mb-3= trainingFlash.error
      if trainingFlash.success
        .alert.alert-success.mt-3.mb-3= trainingFlash.success
      if conversationSource !== 'conversation5'
        p.text-muted.mb-0 Training entries can only be created from saved chat5 conversations.
      else if conversation._id === 'NEW'
        p.text-muted.mb-0 Save this conversation before adding training entries.
      else
        - const selectableTrainingMessages = Array.isArray(messages) ? messages.map((msg, idx) => ({ msg, index: (chat5MessageWindow.loadedStart || 0) + idx })).filter((entry) => trainingText(entry.msg).length > 0) : [];
        form.chat5-training-form(method="post", action="/chat5/training-entries")
          input(type="hidden", name="conversation_id", value=conversation._id.toString())
          .row
            .col-md-6.mb-3
              label.chat5-input-label.form-label(for="trainingGroupId") Training group
              select#trainingGroupId.form-select(name="group_id", required, disabled=trainingGroupOptions.length === 0)
                if trainingGroupOptions.length
                  each group in trainingGroupOptions
                    option(value=group.groupId)= `${group.groupId} (${group.stats && group.stats.entryCount ? group.stats.entryCount : 0} entries)`
                else
                  option(value="") Create a training group first
            .col-md-6.mb-3
              label.chat5-input-label.form-label(for="trainingNotes") Notes
              input#trainingNotes.form-control(type="text", name="notes", maxlength="2000", placeholder="Optional note for this entry")
          +chat5MessageLoadControls()
          p#chat5TrainingEmpty.text-muted(class={ 'd-none': selectableTrainingMessages.length > 0 }) No text messages are available for training selection.
          .chat5-training-message-list#chat5TrainingMessageList
            each entry in selectableTrainingMessages
              - const m = entry.msg;
              - const messageId = m._id.toString();
              - const messageIndex = entry.index;
              - const sender = typeof m.user_id === 'string' && m.user_id.trim().length > 0 ? m.user_id : 'Unknown';
              - const trainingUsage = trainingUsageByMessage[messageId] || null;
              article.chat5-training-message-option(data-message-id=messageId, data-message-index=messageIndex, class={ 'chat5-training-message-option--in-training': !!trainingUsage })
                .chat5-training-message-selectors
                  .form-check
                    input.form-check-input(type="checkbox", id=`trainingPrompt-${messageId}`, name="prompt_message_ids", value=messageId)
                    label.form-check-label(for=`trainingPrompt-${messageId}`) Prompt
                  .form-check
                    input.form-check-input(type="radio", id=`trainingOutput-${messageId}`, name="output_message_id", value=messageId)
                    label.form-check-label(for=`trainingOutput-${messageId}`) Output
                .chat5-training-message-preview
                  .d-flex.flex-wrap.gap-2.align-items-center
                    strong= `#${messageIndex} ${sender}`
                    code= messageId
                    if trainingUsage
                      span.chat5-training-usage-badge(title=trainingUsageTitle(trainingUsage))= trainingUsageLabel(trainingUsage)
                  p.mb-0= trainingPreview(m)
          .chat5-update-actions.d-flex.justify-content-end.flex-wrap.gap-2
            button#chat5TrainingSubmit.btn.btn-success(type="submit", disabled=trainingGroupOptions.length === 0 || selectableTrainingMessages.length < 2) Add entry

        hr.chat5-divider
        h3 Existing entries for this conversation
        if trainingEntryOptions.length
          .chat5-training-entry-list
            each entry in trainingEntryOptions
              article.chat5-training-entry
                .chat5-training-entry-main
                  .d-flex.flex-wrap.gap-2.align-items-center
                    strong= entry.groupId
                    span.badge.chat5-badge.chat5-badge--tag= `${entry.promptMessageIds.length} prompt${entry.promptMessageIds.length === 1 ? '' : 's'}`
                    small.text-muted= formatTimestamp(entry.createdAt)
                  .chat5-training-entry-ids
                    div
                      b Prompt:
                      span= entry.promptMessageIds.join(', ')
                    div
                      b Output:
                      span= entry.outputMessageId
                  if entry.notes
                    p.mb-0.text-muted= entry.notes
                form(method="post", action=`/chat5/training-entries/${entry._id.toString()}/delete`)
                  input(type="hidden", name="conversation_id", value=conversation._id.toString())
                  button.btn.btn-outline-danger.btn-sm(type="submit") Delete
        else
          p.text-muted.mb-0 No training entries have been added for this conversation yet.
