extends layout

block content
  - const personaOptions = Array.isArray(personalities) ? personalities : [];
  - const responseTypeOptions = Array.isArray(responseTypes) ? responseTypes : [];
  - const availableToolOptions = typeof availableTools !== 'undefined' && Array.isArray(availableTools) ? availableTools : [];
  - const trainingGroupOptions = typeof trainingGroups !== 'undefined' && Array.isArray(trainingGroups) ? trainingGroups : [];
  - const trainingEntryOptions = typeof trainingEntries !== 'undefined' && Array.isArray(trainingEntries) ? trainingEntries : [];
  -
    const trainingUsageByMessage = {};
    const ensureTrainingUsage = (messageId) => {
      const id = messageId ? messageId.toString() : '';
      if (!id) return null;
      if (!trainingUsageByMessage[id]) {
        trainingUsageByMessage[id] = {
          promptCount: 0,
          outputCount: 0,
          entryIds: [],
          groupIds: [],
        };
      }
      return trainingUsageByMessage[id];
    };
    trainingEntryOptions.forEach((entry) => {
      const entryId = entry && entry._id ? entry._id.toString() : '';
      const groupId = entry && entry.groupId ? entry.groupId.toString() : '';
      const promptIds = Array.isArray(entry && entry.promptMessageIds) ? entry.promptMessageIds : [];
      promptIds.forEach((promptId) => {
        const usage = ensureTrainingUsage(promptId);
        if (!usage) return;
        usage.promptCount += 1;
        if (entryId && usage.entryIds.indexOf(entryId) < 0) usage.entryIds.push(entryId);
        if (groupId && usage.groupIds.indexOf(groupId) < 0) usage.groupIds.push(groupId);
      });
      const usage = ensureTrainingUsage(entry && entry.outputMessageId);
      if (!usage) return;
      usage.outputCount += 1;
      if (entryId && usage.entryIds.indexOf(entryId) < 0) usage.entryIds.push(entryId);
      if (groupId && usage.groupIds.indexOf(groupId) < 0) usage.groupIds.push(groupId);
    });
    const trainingUsageLabel = (usage) => {
      if (!usage) return '';
      const roles = [];
      if (usage.promptCount > 0) roles.push('prompt');
      if (usage.outputCount > 0) roles.push('output');
      const entryCount = Array.isArray(usage.entryIds) ? usage.entryIds.length : 0;
      const countText = entryCount > 1 ? ` (${entryCount} entries)` : '';
      return `In training: ${roles.join(' + ')}${countText}`;
    };
    const trainingUsageTitle = (usage) => {
      if (!usage) return '';
      const groups = Array.isArray(usage.groupIds) && usage.groupIds.length ? ` Groups: ${usage.groupIds.join(', ')}.` : '';
      return `${trainingUsageLabel(usage)}.${groups}`;
    };
  - const trainingFlash = typeof trainingStatus !== 'undefined' && trainingStatus ? trainingStatus : {};
  - const chat5MessageWindow = typeof messageWindow !== 'undefined' && messageWindow ? messageWindow : { batchSize: 25, initialLimit: 25, total: Array.isArray(messages) ? messages.length : 0, loadedStart: 0, loadedEnd: Array.isArray(messages) ? messages.length : 0, hasMoreOlder: false, source: conversationSource };
  h2#conversation_title.chat5-title= conversation.title
  p#id.chat5-meta(data-source=conversationSource)= conversation._id
  .chat5-header-actions.d-flex.gap-2.mb-3
    a.btn.btn-outline-primary(href=`/chat4/createknowledgefromchat/${conversation._id.toString()}`) Create knowledge entry
    a.btn.btn-outline-secondary(href=`/chat5/voice/${conversation._id.toString()}`) Open voice view
  - const selectedTools = Array.isArray(conversation.metadata && conversation.metadata.tools) ? conversation.metadata.tools : []
  - 
    const toPositiveInt = (value, fallback = 25) => {
      const parsed = Number(value);
      return Number.isFinite(parsed) && parsed > 0 ? Math.floor(parsed) : fallback;
    };
  - 
    const formatTimestamp = (value) => {
      if (!value) return 'Unknown';
      const dateValue = value instanceof Date ? value : new Date(value);
      if (Number.isNaN(dateValue.getTime())) return String(value);
      try {
        return dateValue.toLocaleString('en-US', { dateStyle: 'short', timeStyle: 'short' });
      } catch (err) {
        return dateValue.toISOString();
      }
    };
  -
    const trainingText = (message) => {
      const content = message && message.content && typeof message.content === 'object' ? message.content : {};
      return typeof content.text === 'string' ? content.text.trim() : '';
    };
  -
    const trainingPreview = (message) => {
      const text = trainingText(message).replace(/\s+/g, ' ');
      if (text.length <= 220) return text;
      return `${text.slice(0, 217)}...`;
    };
  - 
    const parseJsonLikeString = (value) => {
      if (typeof value !== 'string') return value;
      const trimmed = value.trim();
      if (!trimmed) return value;
      const firstChar = trimmed[0];
      if (firstChar !== '{' && firstChar !== '[') return value;
      try {
        return JSON.parse(trimmed);
      } catch (err) {
        return value;
      }
    };
  -
    const formatStructuredMessageJson = (message) => {
      if (!message || (message.contentType !== 'function_call' && message.contentType !== 'function_call_output')) {
        return '';
      }
      const content = message.content && typeof message.content === 'object' ? message.content : {};
      const payload = content.raw && typeof content.raw === 'object' ? { ...content.raw } : {};

      if (!payload.type) payload.type = message.contentType;
      if (!payload.call_id && (content.callId || content.toolCallId)) {
        payload.call_id = content.callId || content.toolCallId;
      }
      if (!payload.tool_call_id && !payload.id && content.toolCallId) {
        payload.tool_call_id = content.toolCallId;
      }
      if (!payload.name && content.toolName) {
        payload.name = content.toolName;
      }
      if (!Object.prototype.hasOwnProperty.call(payload, 'arguments') && message.contentType === 'function_call') {
        payload.arguments = content.arguments;
      }
      if (!Object.prototype.hasOwnProperty.call(payload, 'output') && message.contentType === 'function_call_output') {
        payload.output = Object.prototype.hasOwnProperty.call(content, 'output') ? content.output : content.toolOutput;
      }
      if (!Object.prototype.hasOwnProperty.call(payload, 'status') && content.status) {
        payload.status = content.status;
      }
      if (!Object.prototype.hasOwnProperty.call(payload, 'error') && content.error) {
        payload.error = content.error;
      }
      if (!Object.prototype.hasOwnProperty.call(payload, 'result') && content.result) {
        payload.result = content.result;
      }
      if (Object.prototype.hasOwnProperty.call(payload, 'arguments')) {
        payload.arguments = parseJsonLikeString(payload.arguments);
      }
      if (Object.prototype.hasOwnProperty.call(payload, 'output')) {
        payload.output = parseJsonLikeString(payload.output);
      }

      try {
        return JSON.stringify(payload, null, 2);
      } catch (err) {
        return JSON.stringify({
          type: message.contentType,
          call_id: content.callId || content.toolCallId || null,
          error: 'Unable to stringify message payload',
        }, null, 2);
      }
    };
  - const configuredMaxMessages = toPositiveInt(conversation && conversation.metadata && conversation.metadata.maxMessages, 25);
  - const visibleLimit = Math.min(25, configuredMaxMessages);
  - 
    const totalNonHiddenMessages = Array.isArray(messages)
      ? messages.reduce((acc, msg) => acc + (msg && msg.hideFromBot ? 0 : 1), 0)
      : 0;
  - const olderNonHiddenTarget = Math.max(0, totalNonHiddenMessages - visibleLimit);
  - const olderChunks = [];
  - let currentChunk = null;
  - let currentChunkNonHidden = 0;
  - let processedNonHidden = 0;
  - const visibleMessages = [];
  - 
    if (Array.isArray(messages)) {
      messages.forEach((msg) => {
        const isHidden = !!(msg && msg.hideFromBot);
        const isOlder = processedNonHidden < olderNonHiddenTarget;
        if (isOlder) {
          if (!currentChunk) {
            currentChunk = { messages: [], nonHiddenCount: 0 };
            currentChunkNonHidden = 0;
            olderChunks.push(currentChunk);
          }
          currentChunk.messages.push(msg);
          if (!isHidden) {
            currentChunkNonHidden += 1;
            currentChunk.nonHiddenCount = currentChunkNonHidden;
          }
        } else {
          visibleMessages.push(msg);
        }
        if (!isHidden) {
          processedNonHidden += 1;
          if (isOlder && currentChunk && currentChunkNonHidden >= 25) {
            currentChunk = null;
            currentChunkNonHidden = 0;
          }
        }
      });
    }
  mixin chat5RenderMessageCard(m, state)
    - if (!m) return;
    - const sender = typeof m.user_id === 'string' && m.user_id.trim().length > 0 ? m.user_id : 'Unknown';
    - const isBot = sender.toUpperCase() === 'BOT';
    - const content = m.content && typeof m.content === 'object' ? m.content : {};
    - const copyText = content ? (content.text || content.transcript || content.revisedPrompt || content.toolOutput || '') : '';
    - const hasCopyText = typeof copyText === 'string' && copyText.trim().length > 0;
    - const messageLabel = [m._id ? `id ${m._id}` : '', m.contentType ? `type ${m.contentType}` : '', sender ? `user ${sender}` : ''].filter(Boolean).join(', ') || 'message has no id, type, or user';
    - const handledMessageTypes = ["text", "image", "audio", "tool", "reasoning", "function_call", "function_call_output"];
    if !state.lastUser || state.lastUser !== sender
      hr.chat5-divider
      div.userlabel.chat5-user-label(data-user=sender)
        b= sender 
      - state.lastUser = sender
    div(data-id=m._id, class={
        'chat5-message': true,
        'chat5-message--hidden': m.hideFromBot,
        'chat5-message--bot': isBot
      })
      if isBot
        img.chat5-avatar(src='/i/avatar.jpg', alt='Bot avatar')
      if hasCopyText || m.contentType === "text"
        .chat5-message-actions
          if hasCopyText
            button.chat5-copy-button(type='button', aria-label='Copy message text', data-copy-text=copyText) Copy
          if m.contentType === "text"
            button.chat5-embed-button(type='button', aria-label='Embed message (high quality)', data-message-id=m._id, data-conversation-id=conversation && conversation._id ? conversation._id.toString() : '') Embed HQ
      .chat5-message-body
        if m.contentType === "text"
          div.chat5-message-text(id=`${m._id}textout`)
            if typeof content.html === 'string' && content.html.trim().length > 0
              != content.html
            else
              .chat5-message-problem
                strong Empty text message received.
                .chat5-message-problem-details= `${messageLabel}. content.text is empty, null, or missing.`
        if m.contentType === "image"
          if content.image
            img.chat5-message-image(src=`/img/${content.image}`, alt=content.revisedPrompt)
            p.chat5-image-caption
              i= content.revisedPrompt
          else
            .chat5-message-problem
              strong Image message is missing a file name.
              .chat5-message-problem-details= `${messageLabel}. content.image is empty, null, or missing.`
        if m.contentType === "audio"
          - const audioFile = content.audio || content.tts;
          - const audioTranscript = content.transcript || content.text;
          if audioFile
            audio.chat5-message-audio(controls, src=`/mp3/${audioFile}`)
          if audioTranscript
            p.chat5-audio-transcript= audioTranscript
          if !audioFile && !audioTranscript
            .chat5-message-problem
              strong Empty audio message received.
              .chat5-message-problem-details= `${messageLabel}. No audio file or transcript is present.`
        if m.contentType === "tool"
          div.chat5-message-tool
            if content.toolOutput
              i= content.toolOutput
            else
              .chat5-message-problem
                strong Empty tool message received.
                .chat5-message-problem-details= `${messageLabel}. content.toolOutput is empty, null, or missing.`
        if m.contentType === "reasoning"
          div.chat5-message-reasoning
            if typeof content.html === 'string' && content.html.trim().length > 0
              i!= content.html
            else
              .chat5-message-problem
                strong Empty reasoning message received.
                .chat5-message-problem-details= `${messageLabel}. The API response did not include reasoning summary text.`
        if m.contentType === "function_call" || m.contentType === "function_call_output"
          - const structuredJson = formatStructuredMessageJson(m);
          if structuredJson
            pre.chat5-message-json
              code.language-json= structuredJson
          else
            .chat5-message-problem
              strong= `Unable to display ${m.contentType} message.`
              .chat5-message-problem-details= `${messageLabel}. No structured payload could be built from the message content.`
        if handledMessageTypes.indexOf(m.contentType) === -1
          .chat5-message-problem
            strong Unsupported message type received.
            .chat5-message-problem-details= `${messageLabel}. contentType "${m.contentType || 'missing'}" is not handled by the browser renderer.`
  mixin chat5RenderHiddenGroup(group, state)
    - if (!group || !group.length) return;
    - const firstHidden = group[0];
    - const lastHidden = group[group.length - 1];
    - const hiddenLabel = group.length === 1 ? '1 hidden message' : `${group.length} hidden messages`;
    - const firstTime = formatTimestamp(firstHidden && firstHidden.timestamp);
    - const lastTime = formatTimestamp(lastHidden && lastHidden.timestamp);
    - const timeRange = firstTime === lastTime ? firstTime : `${firstTime} - ${lastTime}`;
    details.chat5-hidden-group
      summary.chat5-hidden-summary
        span.chat5-hidden-summary-label= hiddenLabel
        span.chat5-hidden-summary-time= timeRange
      .chat5-hidden-body
        each hiddenMsg in group
          +chat5RenderMessageCard(hiddenMsg, state)
  mixin chat5RenderMessageList(list, state)
    - if (!Array.isArray(list) || !list.length) return;
    - const renderState = state || { lastUser: null };
    - let buffer = [];
    each msg, idx in list
      if msg && msg.hideFromBot
        - buffer.push(msg);
        - const nextMsg = list[idx + 1];
        if !(nextMsg && nextMsg.hideFromBot)
          +chat5RenderHiddenGroup(buffer, renderState)
          - buffer = [];
      else
        if buffer.length
          +chat5RenderHiddenGroup(buffer, renderState)
          - buffer = [];
        +chat5RenderMessageCard(msg, renderState)
    if buffer.length
      +chat5RenderHiddenGroup(buffer, renderState)
  mixin chat5RenderHistoryChunk(chunk)
    - if (!chunk || !Array.isArray(chunk.messages) || !chunk.messages.length) return;
    - const chunkState = { lastUser: null };
    - const firstMessage = chunk.messages[0];
    - const lastMessage = chunk.messages[chunk.messages.length - 1];
    - const rangeStart = formatTimestamp(firstMessage && firstMessage.timestamp);
    - const rangeEnd = formatTimestamp(lastMessage && lastMessage.timestamp);
    - const rangeLabel = rangeStart === rangeEnd ? rangeStart : `${rangeStart} - ${rangeEnd}`;
    - const nonHiddenCount = chunk.nonHiddenCount || chunk.messages.reduce((acc, m) => acc + (m && m.hideFromBot ? 0 : 1), 0);
    details.chat5-history-chunk
      summary.chat5-history-chunk-summary
        span.chat5-chunk-pill= `Show ${nonHiddenCount} older messages`
        span.chat5-chunk-range= rangeLabel
      .chat5-chunk-body
        +chat5RenderMessageList(chunk.messages, chunkState)
  mixin chat5MessageLoadControls()
    - const loadedCount = Math.max(0, (chat5MessageWindow.loadedEnd || 0) - (chat5MessageWindow.loadedStart || 0));
    - const hasMoreOlder = !!chat5MessageWindow.hasMoreOlder;
    .chat5-message-load-controls(data-chat5-load-controls, class={ 'd-none': chat5MessageWindow.source !== 'conversation5' || (!hasMoreOlder && chat5MessageWindow.total <= loadedCount) })
      button.btn.btn-outline-primary.btn-sm(type="button", data-chat5-load-more, disabled=!hasMoreOlder)= `Load ${chat5MessageWindow.batchSize || 25} older`
      button.btn.btn-outline-secondary.btn-sm(type="button", data-chat5-load-all, disabled=!hasMoreOlder) Load all
      span.small.text-muted(data-chat5-load-status)= `Showing ${loadedCount} of ${chat5MessageWindow.total || loadedCount} messages`
  +chat5MessageLoadControls()
  #conversationContainer.chat5-history
    if olderChunks.length
      each chunk, chunkIdx in olderChunks
        +chat5RenderHistoryChunk(chunk)
    - const visibleState = { lastUser: null };
    if visibleMessages.length
      +chat5RenderMessageList(visibleMessages, visibleState)
    else if !olderChunks.length
      p#chat5EmptyMessages.text-muted.mb-0 No messages yet.
